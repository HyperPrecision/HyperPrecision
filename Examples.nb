                    "HyperPrecision`Private`infoser"}], "]"}]}], ";", 
                    RowBox[{"Order", "=", 
                    RowBox[{"Max", "[", 
                    
                    RowBox[{"HyperPrecision`Private`FindHypergeometricOrder", 
                    "[", 
                    
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
                    "]"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`MaxDerivativeOrder", "=", 
                    RowBox[{"Order", "+", "2"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`pde", "=", 
                    RowBox[{"PDEGenerator", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    ",", "HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`funcSymbol"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`rules", "=", 
                    RowBox[{"Flatten", "[", 
                    RowBox[{"Solve", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"#1", "\[Equal]", "0"}], "&"}], ")"}], "/@", 
                    "HyperPrecision`Private`pde"}], ",", 
                    
                    RowBox[{"HyperPrecision`Private`FindCornerDerivativesN", 
                    "[", 
                    RowBox[{
                    
                    RowBox[{"Variables", "[", "HyperPrecision`Private`pde", 
                    "]"}], ",", "HyperPrecision`Private`funcSymbol"}], 
                    "]"}]}], "]"}], "]"}]}], ";", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`HolonomicRankFF", "[", 
