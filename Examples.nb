Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"Pi", "/", 
         RowBox[{"Sqrt", "[", "X", "]"}]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Log", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"v12", " ", "+", " ", 
             RowBox[{"Sqrt", "[", "X", "]"}]}], ")"}], "/", 
           RowBox[{"(", 
            RowBox[{"v12", " ", "-", " ", 
             RowBox[{"Sqrt", "[", "X", "]"}]}], ")"}]}], "]"}], "\n", "  ", "-",
          " ", 
         RowBox[{"\[Epsilon]", " ", 
          RowBox[{"(", "\n", "      ", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}], " ", 
             RowBox[{
              RowBox[{"Log", "[", 
               RowBox[{"v11", "/", 
                RowBox[{"v13", "^", "2"}]}], "]"}], "^", "2"}]}], "\n", 
            "    ", "-", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "/", "2"}], ")"}], " ", 
             RowBox[{
              RowBox[{"Log", "[", 
               RowBox[{"v22", "/", 
                RowBox[{"v23", "^", "2"}]}], "]"}], "^", "2"}]}], "\n", 
            "    ", "+", " ", 
            RowBox[{"2", " ", 
             RowBox[{"PolyLog", "[", 
              RowBox[{"2", ",", " ", 
               RowBox[{"1", " ", "-", " ", 
                RowBox[{"v13", "/", 
