Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Epsilon]I", "=", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["10", 
      RowBox[{"-", "17"}]]}], "I"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"result", "[", 
    RowBox[{"x0_", ",", "y0_", ",", "z0_"}], "]"}], " ", ":=", " ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Series", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"pre1", "[", 
            RowBox[{
             RowBox[{"x0", "+", "\[Epsilon]I"}], ",", 
