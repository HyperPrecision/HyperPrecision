Cell[BoxData[
 RowBox[{
  RowBox[{"Snum", "[", 
   RowBox[{"u0_", ",", "v0_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"result", ",", "pre", ",", "ser"}], "}"}], ",", "\n", "\n", 
    RowBox[{
     RowBox[{"result", " ", "=", " ", 
      RowBox[{"{", "}"}]}], ";", "\n", 
     RowBox[{"Monitor", "[", 
      RowBox[{
       RowBox[{"Table", "[", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"pre", " ", "=", " ", 
           RowBox[{"N", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"prefactor", "[", 
                RowBox[{"x2", ",", "x3"}], "]"}], "[", 
               RowBox[{"[", "ii", "]"}], "]"}], "/.", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"x2", "->", "u0"}], ",", " ", 
                RowBox[{"x3", "->", "v0"}]}], "}"}]}], ",", "30"}], "]"}]}], ";",
           "\n", 
          RowBox[{"ser", " ", "=", 
           RowBox[{"Block", "[", 
            RowBox[{
             RowBox[{"{", "Print", "}"}], ",", " ", 
             RowBox[{
              RowBox[{
               RowBox[{"HypExpand", "[", 
                RowBox[{"#", ",", 
                 RowBox[{"{", "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"x2", "->", " ", "u0"}], ",", 
                   RowBox[{"x3", "->", " ", "v0"}]}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"eps", ",", "0"}], "}"}], ",", "20"}], "]"}], "&"}],
               "@", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"FfullSer", "[", 
                 RowBox[{"x2", ",", "x3"}], "]"}], "[", 
                RowBox[{"[", "ii", "]"}], "]"}], ")"}]}]}], "]"}]}], ";", 
          "\n", 
          RowBox[{"result", " ", "=", " ", 
           RowBox[{"AppendTo", "[", 
            RowBox[{"result", ",", 
             RowBox[{"Total", "[", 
              RowBox[{"pre", " ", "ser"}], "]"}]}], "]"}]}], ";"}], "\n", ",", 
         RowBox[{"{", 
          RowBox[{"ii", ",", "1", ",", 
           RowBox[{"Length", "[", 
            RowBox[{"FfullSer", "[", 
             RowBox[{"x2", ",", "x3"}], "]"}], "]"}]}], "}"}]}], "]"}], ",", 
       "ii"}], "]"}], ";", "\n", 
     RowBox[{"Re", "[", 
      RowBox[{"Total", "[", "result", "]"}], "]"}]}]}], "\n", 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.987982516212707*^9, 3.9879825286381617`*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"cc1bf6a5-ec65-4c28-b862-0015e7745338"],

