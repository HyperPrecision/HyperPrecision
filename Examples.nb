           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"FindHolonomicRank[HypSeries, SumVar, Vars] returns \
the holonomic rank of the Pfaffian system associated with the hypergeometric \
series HypSeries.\\nHypSeries is a hypergeometric series given in terms of \
Pochhammer functions.\\nSumVar is the list of summation indices appearing in \
HypSeries:\\n  \[Bullet] {m, n, ...}\\nVars is the list of kinematic \
variables:\\n  \[Bullet] {x, y, ...}\\nThe result is the pair {N, Relations}, \
where N is the holonomic rank and Relations is a (possibly empty) list of \
linear relations among the candidate basis elements that reduce the lattice \
basis to a basis of size N.\\nExamples:\\n  \
FindHolonomicRank[Pochhammer[a,m+n] Pochhammer[b,m] Pochhammer[b',n] / \
(Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, {x, y}]\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"FindHolonomicRank", "[", 
                    
                    RowBox[{
                    "HyperPrecision`Private`exp_", ",", 
                    "HyperPrecision`Private`indices_List", ",", 
                    "HyperPrecision`Private`vars_List"}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"Order", ",", "HyperPrecision`Private`pde", ",", 
                    "HyperPrecision`Private`rules", ",", 
                    "HyperPrecision`Private`funcSymbol", ",", 
                    "HyperPrecision`Private`infoser", ",", 
                    "HyperPrecision`Private`genser", ",", 
                    "HyperPrecision`Private`MaxDerivativeOrder"}], "}"}], ",", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`funcSymbol", "=", 
                    "\[FormalF]"}], ";", 
                    RowBox[{"HyperPrecision`Private`infoser", "=", 
                    RowBox[{"HyperPrecision`Private`info", "[", 
                    
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`exp"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`genser", "=", 
                    RowBox[{"HyperPrecision`Private`generalser", "[", 
