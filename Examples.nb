Cell[BoxData[
 RowBox[{
  RowBox[{"Snum", "[", 
   RowBox[{"u0_", ",", "v0_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"result", ",", "pre", ",", "ser"}], "}"}], ",", "\n", "\n", 
    RowBox[{
     RowBox[{"result", " ", "=", " ", 
