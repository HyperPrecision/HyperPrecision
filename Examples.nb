Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "\[CapitalDelta]1", ",", "\[CapitalDelta]2", ",", "\[CapitalDelta]3"}], 
     "}"}], "=", 
    RowBox[{"\[CapitalDelta]", "/@", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2", ",", "2"}], "}"}]}]}], ";"}], "    ", 
  RowBox[{"(*", " ", 
   RowBox[{"Set", " ", "1", " ", "Value"}], " ", "*)"}], "   "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
    "\[CapitalTheta]1", ",", "\[CapitalTheta]2", ",", "\[CapitalTheta]3"}], 
    "}"}], "=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
      "\[CapitalDelta]1", "+", "\[CapitalDelta]2", "+", "\[CapitalDelta]3"}], 
      ")"}], "/", "2"}], "-", 
    RowBox[{"{", 
     RowBox[{
     "\[CapitalDelta]1", ",", "\[CapitalDelta]2", ",", "\[CapitalDelta]3"}], 
     "}"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[CapitalTheta]", "=", 
   RowBox[{
   "\[CapitalTheta]1", "+", "\[CapitalTheta]2", "+", "\[CapitalTheta]3"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"N\[CapitalDelta]", "=", 
   RowBox[{
    RowBox[{"Pi", "^", "\[Eta]"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Gamma", "[", "\[CapitalTheta]1", "]"}], " ", 
      RowBox[{"Gamma", "[", "\[CapitalTheta]2", "]"}], " ", 
      RowBox[{"Gamma", "[", "\[CapitalTheta]3", "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"\[Eta]", "/", "2"}], "]"}]}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"dyz", "=", "1"}], ";"}], " "}]}], "Input",
