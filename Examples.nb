            StyleBox["\<\"HypExpand[HypSeries, ParSub, VarSub, {Eps, Ord}, \
NPrec, opts] numerically expands a hypergeometric series HypSeries around \
Eps=0 up to order Ord with NPrec correct digits.\\nHypSeries is a \
hypergeometric series given in terms of Pochhammer functions.\\nParSub is the \
list of substitution rules for the Pochhammer parameters:\\n  \[Bullet] {a \
\[Rule] 1+\[Epsilon], b \[Rule] 1/2, c \[Rule] 2-\[Epsilon], ...}\\nVarSub is \
the list of substitution rules for the kinematic variables, specifying the \
evaluation point:\\n  \[Bullet] {x \[Rule] 1/5, y \[Rule] 1/4, ...}\\nThe \
result is the list of Laurent coefficients from the lowest non-vanishing \
order to Ord.\\nOptions:\\n  \[Bullet] IDelta      (default: -I)    \
\[LongDash] infinitesimal imaginary shift\\n  \[Bullet] VerboseMode (default: \
False) \[LongDash] print progress information\\n  \[Bullet] ParallelRun \
(default: True)  \[LongDash] use parallel evaluation\\nExamples:\\n  \
HypExpand[Pochhammer[a,m+n] Pochhammer[b1,m] Pochhammer[b2,n] / \
(Pochhammer[c,m+n] m! n!) x^m y^n,\\n            {a \[Rule] 1, b1 \[Rule] \
1/2, b2 \[Rule] 1/3, c \[Rule] 2}, {x \[Rule] 1/5, y \[Rule] 1/4}, \
{\[Epsilon], 2}, 50]\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           TagBox[
            ButtonBox[
             PaneSelectorBox[{False->
              
              DynamicBox[FEPrivate`FrontEndResource[
               "FEBitmaps", "DownPointerOpener"],
               ImageSizeCache->{12.5, {3.34375, 9.15625}}], True->
              
              DynamicBox[FEPrivate`FrontEndResource[
               "FEBitmaps", "DownPointerOpenerHot"],
               ImageSizeCache->{12.5, {3.34375, 9.15625}}]}, Dynamic[
              System`InformationDump`mouseOver$$]],
             Alignment->Left,
             Appearance->{"Default" -> None},
             
             ButtonFunction:>FEPrivate`Set[
              System`InformationDump`open$$, True],
             Evaluator->Automatic,
             FrameMargins->{{9, 0}, {0, 0}},
             ImageMargins->0,
             ImageSize->Full,
             Method->"Preemptive"],
            
            EventHandlerTag[{
             "MouseEntered" :> 
              FEPrivate`Set[System`InformationDump`mouseOver$$, True], 
              "MouseExited" :> 
              FEPrivate`Set[System`InformationDump`mouseOver$$, False], 
              Method -> "Preemptive", PassEventsDown -> Automatic, 
              PassEventsUp -> True}]],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], "\[SpanFromLeft]"}
        },
        AutoDelete->False,
        FrameStyle->Directive[
          GrayLevel[0.8], 
          Thickness[Tiny]],
        GridBoxAlignment->{"Columns" -> {Left, Right}, "Rows" -> {{Center}}},
        GridBoxDividers->{
         "Columns" -> {{None}}, "Rows" -> {False, {True}, False}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}],
       "Grid"]}, Dynamic[System`InformationDump`open$$],
      BaselinePosition->Baseline,
      FrameMargins->0,
      ImageSize->Automatic],
     DynamicModuleValues:>{}],
    BaseStyle->"InformationGridFrame",
    StripOnInput->False], "InformationGridPlain",
   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "HypExpand[HypSeries, ParSub, VarSub, {Eps, Ord}, NPrec, opts] \
numerically expands a hypergeometric series HypSeries around Eps=0 up to \
order Ord with NPrec correct digits.\nHypSeries is a hypergeometric series \
given in terms of Pochhammer functions.\nParSub is the list of substitution \
rules for the Pochhammer parameters:\n  \[Bullet] {a \[Rule] 1+\[Epsilon], b \
\[Rule] 1/2, c \[Rule] 2-\[Epsilon], ...}\nVarSub is the list of substitution \
rules for the kinematic variables, specifying the evaluation point:\n  \
\[Bullet] {x \[Rule] 1/5, y \[Rule] 1/4, ...}\nThe result is the list of \
Laurent coefficients from the lowest non-vanishing order to Ord.\nOptions:\n  \
\[Bullet] IDelta      (default: -I)    \[LongDash] infinitesimal imaginary \
shift\n  \[Bullet] VerboseMode (default: False) \[LongDash] print progress \
information\n  \[Bullet] ParallelRun (default: True)  \[LongDash] use \
parallel evaluation\nExamples:\n  HypExpand[Pochhammer[a,m+n] \
Pochhammer[b1,m] Pochhammer[b2,n] / (Pochhammer[c,m+n] m! n!) x^m y^n,\n      \
      {a \[Rule] 1, b1 \[Rule] 1/2, b2 \[Rule] 1/3, c \[Rule] 2}, {x \[Rule] \
1/5, y \[Rule] 1/4}, {\[Epsilon], 2}, 50]", "Documentation" -> None, 
    "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, HyperPrecision`HypExpand, {HyperPrecision`HypExpand[
         Pattern[HyperPrecision`Private`HypSeries, 
          Blank[]], 
         Pattern[HyperPrecision`Private`ParSubRaw, 
          Blank[]], 
         Pattern[HyperPrecision`Private`VarsSubRaw, 
          Blank[]], {
          Pattern[HyperPrecision`Private`Eps, 
           Blank[]], 
          Pattern[HyperPrecision`Private`Ord, 
           Blank[]]}, 
         Pattern[HyperPrecision`Private`NPrec, 
          Blank[]], 
         Pattern[HyperPrecision`Private`opts, 
          OptionsPattern[]]] :> 
       Module[{HyperPrecision`Private`SumVar, 
          HyperPrecision`Private`ActualVar, HyperPrecision`Private`VarSubKeys,
           HyperPrecision`Private`VarsSub, HyperPrecision`Private`infoser, 
          HyperPrecision`Private`NewVarsSubRaw, HyperPrecision`Private`genser,
           HyperPrecision`Private`newinfoser}, 
         HyperPrecision`Private`SumVar = 
          HyperPrecision`Private`indices[HyperPrecision`Private`HypSeries]; 
         HyperPrecision`Private`VarSubKeys = 
          Keys[HyperPrecision`Private`VarsSubRaw]; 
         HyperPrecision`Private`infoser = 
          HyperPrecision`Private`info[
           HyperPrecision`Private`SumVar, HyperPrecision`Private`HypSeries]; 
         HyperPrecision`Private`newinfoser = 
          ReplacePart[
           HyperPrecision`Private`infoser, {2, -1} -> 
            HyperPrecision`Private`VarSubKeys]; 
         HyperPrecision`Private`NewVarsSubRaw = 
          Thread[HyperPrecision`Private`VarSubKeys -> ReplaceAll[
              Part[HyperPrecision`Private`infoser, 2, -1], 
              HyperPrecision`Private`VarsSubRaw]]; Return[
           HyperPrecision`Private`HypExpand0[
            HyperPrecision`Private`infotoseries[
            HyperPrecision`Private`SumVar, HyperPrecision`Private`newinfoser], 
            Rationalize[
            HyperPrecision`Private`ParSubRaw, 
             10^(-HyperPrecision`Private`NPrec)], 
            HyperPrecision`Private`SumVar, 
            Rationalize[
            HyperPrecision`Private`NewVarsSubRaw, 
             10^(-HyperPrecision`Private`NPrec)], {
            HyperPrecision`Private`Eps, HyperPrecision`Private`Ord}, 
            HyperPrecision`Private`NPrec, HyperPrecision`Private`opts]]; 
         Null]}], "SubValues" -> None, "DefaultValues" -> None, "NValues" -> 
    None, "FormatValues" -> None, 
    "Options" -> {
     HyperPrecision`IDelta -> Complex[0, -1], HyperPrecision`VerboseMode -> 
      False, HyperPrecision`ParallelRun -> True}, "Attributes" -> {}, 
    "FullName" -> "HyperPrecision`HypExpand"|>, False]]], "Output",
