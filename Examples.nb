                    "]"}]}], ";", 
                    
                    RowBox[{"HyperPrecision`Private`Ord", "=", 
                    "HyperPrecision`Private`OrdRaw"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{"HyperPrecision`Private`\[Epsilon]Q", ",", 
                    RowBox[{"HyperPrecision`Private`\[Epsilon]LOOut", "=", 
                    RowBox[{"HyperPrecision`Private`\[Epsilon]LO", "[", 
                    
                    RowBox[{"HyperPrecision`Private`Ser", ",", 
