     RowBox[{"LauricellaFC", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"1", ",", "\[Epsilon]"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Epsilon]", ",", 
