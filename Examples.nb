   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "FindPfaffianSystem[HypSeries, SumVar, Vars] derives the Pfaffian system \
associated with HypSeries, automatically constructing a basis of derivatives \
from the holonomic order of the system.\nHypSeries is a hypergeometric series \
given in terms of Pochhammer functions.\nSumVar is the list of summation \
indices appearing in HypSeries:\n  \[Bullet] {m, n, ...}\nVars is the list of \
kinematic variables:\n  \[Bullet] {x, y, ...}\nThe result is the 4-tuple \
{HypSeries, SumVar, Pfaffian, Basis}, where Pfaffian is the Association <|Var \
\[Rule] Matrix|> of connection matrices and Basis is the list of basis \
elements. The 4-tuple is the input format expected by TransportDE[].\n\
Examples:\n  FindPfaffianSystem[Pochhammer[a,m+n] Pochhammer[b,m] \
Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, {x, y}]", 
    "Documentation" -> None, "OwnValues" -> None, "UpValues" -> None, 
    "DownValues" -> 
    Information`InformationValueForm[
     DownValues, HyperPrecision`FindPfaffianSystem, {
      HyperPrecision`FindPfaffianSystem[
         Pattern[HyperPrecision`Private`exp, 
          Blank[]], 
         Pattern[HyperPrecision`Private`indices, 
          Blank[List]], 
         Pattern[HyperPrecision`Private`vars, 
          Blank[List]]] :> 
       Module[{HyperPrecision`Private`pde, HyperPrecision`Private`MaxOrder, 
          HyperPrecision`Private`rules, HyperPrecision`Private`F, 
          HyperPrecision`Private`infoser, HyperPrecision`Private`genser, 
          HyperPrecision`Private`result, HyperPrecision`Private`order, 
          HyperPrecision`Private`basis, HyperPrecision`Private`funcSymbol, 
          HyperPrecision`Private`de}, 
         HyperPrecision`Private`funcSymbol = \[FormalF]; 
         HyperPrecision`Private`infoser = 
          HyperPrecision`Private`info[
           HyperPrecision`Private`indices, HyperPrecision`Private`exp]; 
         HyperPrecision`Private`genser = 
          HyperPrecision`Private`generalser[
           HyperPrecision`Private`indices, HyperPrecision`Private`infoser]; 
         HyperPrecision`Private`order = Max[
            HyperPrecision`Private`FindHypergeometricOrder[
            HyperPrecision`Private`indices, HyperPrecision`Private`vars, 
             Part[HyperPrecision`Private`genser, 1]]]; 
         HyperPrecision`Private`basis = Map[If[
             MatchQ[
              Head[#], 
              Derivative[
               BlankSequence[]][HyperPrecision`Private`funcSymbol]], # 
             Apply[Times, HyperPrecision`Private`vars^Apply[List, 
                 Part[#, 0, 0]]], #]& , 
            SortBy[
             HyperPrecision`Private`GenerateLatticeBasis[
             HyperPrecision`Private`funcSymbol, HyperPrecision`Private`vars, 
              HyperPrecision`Private`order], {
             HyperPrecision`Private`TotalDerivOrder, 
              HyperPrecision`Private`MaxIndexOrder}]]; 
         HyperPrecision`Private`MaxOrder = Total[
            Cases[
             HyperPrecision`Private`FindCornerDerivativesN[
              Variables[HyperPrecision`Private`basis], 
              HyperPrecision`Private`funcSymbol], Derivative[
               Pattern[HyperPrecision`Private`seq, 
                BlankSequence[]]][
               BlankSequence[]][
               BlankSequence[]] :> Total[{HyperPrecision`Private`seq}], {
             0, Infinity}]]; 
         HyperPrecision`Private`pde = HyperPrecision`PDEGenerator[
            Part[HyperPrecision`Private`genser, 1], 
            HyperPrecision`Private`indices, HyperPrecision`Private`vars, 
            HyperPrecision`Private`funcSymbol]; 
         HyperPrecision`Private`rules = Flatten[
            Solve[
             Map[# == 0& , HyperPrecision`Private`pde], 
             HyperPrecision`Private`FindCornerDerivativesN[
              Variables[HyperPrecision`Private`pde], 
              HyperPrecision`Private`funcSymbol]]]; 
         HyperPrecision`Private`result = 
          HyperPrecision`Private`FindPfaffianSystemFF[
            Join[HyperPrecision`Private`rules, 
             Flatten[
              Map[
              HyperPrecision`Private`FindDerivativesUniversal[
               HyperPrecision`Private`rules, #]& , 
               Range[HyperPrecision`Private`MaxOrder + 2]]]], 
            HyperPrecision`Private`basis, HyperPrecision`Private`vars, 
            HyperPrecision`Private`funcSymbol]; 
         HyperPrecision`Private`basis = 
          Part[HyperPrecision`Private`result, 1]; 
         HyperPrecision`Private`de = Map[Cancel, 
            ReplaceAll[
             Part[HyperPrecision`Private`result, 2], 
             Part[HyperPrecision`Private`genser, 2]]]; 
         Print["The basis is \[Rule] ", HyperPrecision`Private`basis]; 
         Print["Pfaffian Matrix : ", 
           Thread[Keys[HyperPrecision`Private`de] -> Map[MatrixForm[#]& , 
              Values[HyperPrecision`Private`de]]]]; 
         Return[{HyperPrecision`Private`exp, HyperPrecision`Private`indices, 
            HyperPrecision`Private`de, HyperPrecision`Private`basis}]; 
         Null]}], "SubValues" -> None, "DefaultValues" -> None, "NValues" -> 
    None, "FormatValues" -> None, "Options" -> None, "Attributes" -> {}, 
    "FullName" -> "HyperPrecision`FindPfaffianSystem"|>, False]]], "Output",
 CellChangeTimes->{3.986762411974927*^9, 3.9869390735930653`*^9, 
  3.9869391832166986`*^9},
 CellLabel->"Out[27]=",ExpressionUUID->"b9545648-9fe6-4be6-8068-0f3ae32dd361"]
}, Open  ]],

