                    RowBox[{"HyperPrecision`Private`Ord", "=", "0"}], ";", 
                    
                    RowBox[{"HyperPrecision`Private`\[Epsilon]LOOut", "=", 
                    "0"}]}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`\[Epsilon]LOOut", ">", 
