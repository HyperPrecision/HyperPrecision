          ItemBox[
           PaneBox[
            
            StyleBox["\<\"HornG1[a, b, c, x, y] represents the Horn \
hypergeometric function G1(a,b,c; x,y), defined by the double series\\n\\n  \
G1 = Sum_{m,n>=0} (a)_(m+n) (b)_(n-m) (c)_(m-n) / (m! n!)  x^m \
y^n\\n\\nStandard notation:  G1(a,b,c; x,y)\\nParameters:  upper = {a, b, c}, \
 lower = {} (none)\\n\\nUsage with HypFunctionExpand:\\n  \
HypFunctionExpand[HornG1[a, b, c, x, y], {\[Epsilon],Nterms}, NPrec]\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
