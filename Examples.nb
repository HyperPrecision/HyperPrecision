Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "HypFunctionExpand"}]], "Input",
 CellChangeTimes->{{3.986762268246557*^9, 3.986762271268692*^9}},
 CellLabel->"In[24]:=",ExpressionUUID->"8187d763-8211-4cff-808c-ef14d945ef09"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"HypFunctionExpand[Func, {Eps, Ord}, NPrec, opts] \
numerically expands the hypergeometric function Func around Eps=0 up to order \
Ord with precision NPrec.\\n\\nFunc can be a call to any of the following \
named pre-defined hypergeometric functions, with parameters and variables \
given as follows:\\n\\n  Built-in (Mathematica):\\n  \[Bullet] \
Hypergeometric2F1[a, b, c, x]\\n  \[Bullet] HypergeometricPFQ[{a1,...,ap}, \
{b1,...,bq}, x]   (currently supported only for q = p \[Minus] 1)\\n\\n  \
Appell functions (2 variables):\\n  \[Bullet] AppellF1[a, b1, b2, c, x, y]    \
              -- coincides with LauricellaFD at n=2\\n  \[Bullet] AppellF2[a, \
b1, b2, c1, c2, x, y]             -- coincides with LauricellaFA at n=2\\n  \
\[Bullet] AppellF3[a1, a2, b1, b2, c, x, y]             -- coincides with \
LauricellaFB at n=2\\n  \[Bullet] AppellF4[a, b, c1, c2, x, y]                \
  -- coincides with LauricellaFC at n=2\\n\\n  Horn G- and H-series (2 \
variables, defined within HyperPrecision;    use ?HornG1, ?HornH1, etc. to \
see the series definition and call signature):\\n  \[Bullet] HornG1, HornG2, \
HornG3\\n  \[Bullet] HornH1, HornH2, HornH3, HornH4, HornH5, HornH6, \
HornH7\\n\\n  Lauricella series (n variables, defined within HyperPrecision;  \
  use ?LauricellaFA, ?LauricellaFB, etc. to see the series definition and \
call signature):\\n  \[Bullet] LauricellaFA, LauricellaFB, LauricellaFC, \
LauricellaFD\\n\\n  Options:\\n  \[Bullet] IDelta      (default: -I)    \
\[LongDash] infinitesimal imaginary shift\\n  \[Bullet] VerboseMode (default: \
False) \[LongDash] print progress information\\n  \[Bullet] ParallelRun \
(default: True)  \[LongDash] use parallel evaluation\\n\\nThe result is the \
list of Laurent coefficients from the lowest non-vanishing order to \
Ord.\\n\\nExamples:\\n  HypFunctionExpand[Hypergeometric2F1[1, 1/2 + \
\[Epsilon], 2 - \[Epsilon], 1/3], {\[Epsilon], 2}, 50]\\n  \
HypFunctionExpand[AppellF1[1, 1/2, 1/3, 2, 1/5, 1/4], {\[Epsilon], 2}, 50]\\n \
 HypFunctionExpand[HornH7[1, 1/2, 1/3, 2, 1/5, 1/4], {\[Epsilon], 3}, 50]\\n  \
HypFunctionExpand[LauricellaFD[{1, 1/2, 1/3, 1/4}, {2}, {1/5, 1/6, 1/7}], {\
\[Epsilon], 2}, 50]\\n  HypFunctionExpand[LauricellaFA[{1, 1/2, 1/3}, {2, 3}, \
{1/5, 1/4}], {\[Epsilon], 2}, 50, VerboseMode \[Rule] True]\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"HypFunctionExpand", "[", 
                    RowBox[{
                    RowBox[{"Hypergeometric2F1", "[", 
                    
                    RowBox[{"HyperPrecision`Private`a_", ",", 
                    "HyperPrecision`Private`b_", ",", 
                    "HyperPrecision`Private`c_", ",", 
                    "HyperPrecision`Private`x_"}], "]"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`eps_", ",", 
                    "HyperPrecision`Private`Nterms_"}], "}"}], ",", 
                    "HyperPrecision`Private`Prec_", ",", 
                    RowBox[{"HyperPrecision`Private`opts", ":", 
                    RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
                    RowBox[{"HyperPrecision`Private`HypFunctionExpand0", "[", 
                    RowBox[{
                    RowBox[{"Evaluate", "[", 
                    RowBox[{"{", 
                    RowBox[{"\"PFPm1\"", ",", "2"}], "}"}], "]"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`a", ",", 
                    "HyperPrecision`Private`b", ",", 
                    "HyperPrecision`Private`c"}], "}"}], ",", 
                    RowBox[{"{", "HyperPrecision`Private`x", "}"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`eps", ",", 
                    "HyperPrecision`Private`Nterms"}], "}"}], ",", 
                    "HyperPrecision`Private`Prec", ",", 
                    "HyperPrecision`Private`opts"}], "]"}]}]}, {" "}, {
                    RowBox[{
                    RowBox[{"HypFunctionExpand", "[", 
                    RowBox[{
                    RowBox[{"HypergeometricPFQ", "[", 
                    
                    RowBox[{"HyperPrecision`Private`upper_List", ",", 
