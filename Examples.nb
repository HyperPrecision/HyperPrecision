Pochhammer[b1,m] Pochhammer[b2,n] / (Pochhammer[c,m+n] m! n!) x^m y^n,\n      \
      {a \[Rule] 1, b1 \[Rule] 1/2, b2 \[Rule] 1/3, c \[Rule] 2}, {x \[Rule] \
1/5, y \[Rule] 1/4}, {\[Epsilon], 2}, 50]", "Documentation" -> None, 
