                    "HyperPrecision`Private`ffVars", ",", 
                    "HyperPrecision`Private`ffEqs", ",", 
                    "HyperPrecision`Private`rank", ",", 
                    "HyperPrecision`Private`rawbasis", ",", 
                    "HyperPrecision`Private`seed", ",", 
                    "HyperPrecision`Private`lookfor", ",", 
                    "HyperPrecision`Private`MaxDerivativeOrder", ",", 
                    "HyperPrecision`Private`graphID", ",", 
                    "HyperPrecision`Private`inNode", ",", 
                    "HyperPrecision`Private`solverNode", ",", 
                    "HyperPrecision`Private`hStackNode", ",", 
                    "HyperPrecision`Private`hmStackNode", ",", 
                    "HyperPrecision`Private`learnData", ",", 
