Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"FindPfaffianSystem[HypSeries, SumVar, Vars] derives \
the Pfaffian system associated with HypSeries, automatically constructing a \
basis of derivatives from the holonomic order of the system.\\nHypSeries is a \
hypergeometric series given in terms of Pochhammer functions.\\nSumVar is the \
list of summation indices appearing in HypSeries:\\n  \[Bullet] {m, n, \
...}\\nVars is the list of kinematic variables:\\n  \[Bullet] {x, y, \
...}\\nThe result is the 4-tuple {HypSeries, SumVar, Pfaffian, Basis}, where \
Pfaffian is the Association <|Var \[Rule] Matrix|> of connection matrices and \
Basis is the list of basis elements. The 4-tuple is the input format expected \
by TransportDE[].\\nExamples:\\n  FindPfaffianSystem[Pochhammer[a,m+n] \
Pochhammer[b,m] Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, \
{x, y}]\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"FindPfaffianSystem", "[", 
                    
                    RowBox[{
                    "HyperPrecision`Private`exp_", ",", 
                    "HyperPrecision`Private`indices_List", ",", 
                    "HyperPrecision`Private`vars_List"}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`pde", ",", 
                    "HyperPrecision`Private`MaxOrder", ",", 
                    "HyperPrecision`Private`rules", ",", 
                    "HyperPrecision`Private`F", ",", 
                    "HyperPrecision`Private`infoser", ",", 
                    "HyperPrecision`Private`genser", ",", 
                    "HyperPrecision`Private`result", ",", 
                    "HyperPrecision`Private`order", ",", 
                    "HyperPrecision`Private`basis", ",", 
                    "HyperPrecision`Private`funcSymbol", ",", 
                    "HyperPrecision`Private`de"}], "}"}], ",", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`funcSymbol", "=", 
                    "\[FormalF]"}], ";", 
                    RowBox[{"HyperPrecision`Private`infoser", "=", 
                    RowBox[{"HyperPrecision`Private`info", "[", 
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`exp"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`genser", "=", 
                    RowBox[{"HyperPrecision`Private`generalser", "[", 
                    
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`infoser"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`order", "=", 
                    RowBox[{"Max", "[", 
                    
                    RowBox[{"HyperPrecision`Private`FindHypergeometricOrder", 
                    "[", 
                    
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
                    "]"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`basis", "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"MatchQ", "[", 
                    RowBox[{
                    RowBox[{"Head", "[", "#1", "]"}], ",", 
                    SuperscriptBox["HyperPrecision`Private`funcSymbol", 
                    TagBox[
                    RowBox[{"(", "__", ")"}], Derivative], MultilineFunction -> 
                    None]}], "]"}], ",", 
                    RowBox[{"#1", " ", 
                    RowBox[{"Times", "@@", 
                    SuperscriptBox["HyperPrecision`Private`vars", 
                    RowBox[{"List", "@@", 
                    RowBox[{"#1", "\[LeftDoubleBracket]", 
                    RowBox[{"0", ",", "0"}], "\[RightDoubleBracket]"}]}]]}]}],
                     ",", "#1"}], "]"}], "&"}], ")"}], "/@", 
                    RowBox[{"SortBy", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`GenerateLatticeBasis", 
                    "[", 
                    
                    RowBox[{"HyperPrecision`Private`funcSymbol", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`order"}], "]"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`TotalDerivOrder", ",", 
                    "HyperPrecision`Private`MaxIndexOrder"}], "}"}]}], 
                    "]"}]}]}], ";", 
                    RowBox[{"HyperPrecision`Private`MaxOrder", "=", 
                    RowBox[{"Total", "[", 
                    RowBox[{"Cases", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`FindCornerDerivativesN", 
                    "[", 
                    RowBox[{
                    
                    RowBox[{"Variables", "[", "HyperPrecision`Private`basis", 
                    "]"}], ",", "HyperPrecision`Private`funcSymbol"}], "]"}], 
                    ",", 
                    RowBox[{
                    RowBox[{
                    SuperscriptBox["__", 
                    TagBox[
                    RowBox[{"(", "HyperPrecision`Private`seq__", ")"}], 
                    Derivative], MultilineFunction -> None], "[", "__", "]"}],
                     "\[RuleDelayed]", 
                    RowBox[{"Total", "[", 
                    RowBox[{"{", "HyperPrecision`Private`seq", "}"}], "]"}]}],
                     ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "\[Infinity]"}], "}"}]}], "]"}], 
                    "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`pde", "=", 
                    RowBox[{"PDEGenerator", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    ",", "HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`funcSymbol"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`rules", "=", 
                    RowBox[{"Flatten", "[", 
                    RowBox[{"Solve", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"#1", "\[Equal]", "0"}], "&"}], ")"}], "/@", 
                    "HyperPrecision`Private`pde"}], ",", 
                    
                    RowBox[{"HyperPrecision`Private`FindCornerDerivativesN", 
                    "[", 
                    RowBox[{
                    
                    RowBox[{"Variables", "[", "HyperPrecision`Private`pde", 
                    "]"}], ",", "HyperPrecision`Private`funcSymbol"}], 
                    "]"}]}], "]"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`result", "=", 
                    
                    RowBox[{"HyperPrecision`Private`FindPfaffianSystemFF", 
                    "[", 
                    RowBox[{
                    RowBox[{"Join", "[", 
                    RowBox[{"HyperPrecision`Private`rules", ",", 
                    RowBox[{"Flatten", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`FindDerivativesUniversal",
                     "[", 
                    RowBox[{"HyperPrecision`Private`rules", ",", "#1"}], 
                    "]"}], "&"}], ")"}], "/@", 
                    RowBox[{"Range", "[", 
                    RowBox[{"HyperPrecision`Private`MaxOrder", "+", "2"}], 
                    "]"}]}], "]"}]}], "]"}], ",", 
                    "HyperPrecision`Private`basis", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`funcSymbol"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`basis", "=", 
                    
                    RowBox[{"HyperPrecision`Private`result", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`de", "=", 
                    RowBox[{"Cancel", "/@", 
                    RowBox[{"(", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`result", 
                    "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
                    "/.", "\[VeryThinSpace]", 
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
                    ")"}]}]}], ";", 
                    RowBox[{"Print", "[", 
                    
                    RowBox[{"\"The basis is \[Rule] \"", ",", 
                    "HyperPrecision`Private`basis"}], "]"}], ";", 
                    RowBox[{"Print", "[", 
                    RowBox[{"\"Pfaffian Matrix : \"", ",", 
                    RowBox[{"Thread", "[", 
                    RowBox[{
                    RowBox[{"Keys", "[", "HyperPrecision`Private`de", "]"}], 
                    "\[Rule]", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"MatrixForm", "[", "#1", "]"}], "&"}], ")"}], 
                    "/@", 
                    
                    RowBox[{"Values", "[", "HyperPrecision`Private`de", 
                    "]"}]}]}], "]"}]}], "]"}], ";", 
