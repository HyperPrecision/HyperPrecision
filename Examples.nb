           Not[
            MemberQ[{-I, I}, HyperPrecision`Private`\[CapitalDelta]]], 
           Print["IDelta can be only \[PlusMinus] I"]; Abort[]; Null]; 
         HyperPrecision`Private`Dim = Length[HyperPrecision`Private`Vars]; 
         HyperPrecision`Private`DESolverQ = False; 
         HyperPrecision`Private`DiffExpQ = False; 
         HyperPrecision`Private`DimBasis = Length[
            Part[HyperPrecision`Private`Pfaffian, 1, 1]]; 
         HyperPrecision`Private`StartingQ = False; 
         HyperPrecision`Private`RecomputeBoundaryQ = False; 
         HyperPrecision`Private`BoundaryPoint = 
          ConstantArray[0, HyperPrecision`Private`Dim]; 
         HyperPrecision`Private`BoundaryVal = 
          UnitVector[HyperPrecision`Private`DimBasis, 1]; 
         HyperPrecision`Private`PrintVerbose[
          "Starting Boundary Point \[Rule] ", 
           N[HyperPrecision`Private`BoundaryPoint]]; 
         HyperPrecision`Private`PrintVerbose[
          "Starting Boundary Value \[Rule] ", 
           N[HyperPrecision`Private`BoundaryVal]]; 
         HyperPrecision`Private`PrintVerbose[
          "Running DESolver for numerical evaluation"]; 
         HyperPrecision`Private`BoundaryVal = 
          HyperPrecision`Private`TransportDESolver[
           HyperPrecision`Private`BoundaryPoint, 
            HyperPrecision`Private`BoundaryVal, 
            HyperPrecision`Private`TargetPoint, 
            HyperPrecision`Private`Pfaffian, HyperPrecision`Private`Vars, 
            HyperPrecision`Private`ParSub, HyperPrecision`Private`NPrec, 
            HyperPrecision`Private`\[CapitalDelta], 
            HyperPrecision`Private`Dim, HyperPrecision`Private`VerboseQ, 
            HyperPrecision`Private`ParallelQ, {
            HyperPrecision`Private`Eps, HyperPrecision`Private`Ord}, 
            HyperPrecision`Private`\[Epsilon]LOOut, 
            HyperPrecision`Private`BasisSer, HyperPrecision`Private`SumVar, 
            HyperPrecision`Private`SingCurves]; $MaxPrecision = 
          Infinity; $MinPrecision = 0; If[HyperPrecision`Private`ParallelQ, 
           
           ParallelEvaluate[$MaxPrecision = Infinity; $MinPrecision = 0; 
            Null]]; HyperPrecision`Private`BoundaryVal]}], "SubValues" -> 
    None, "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
