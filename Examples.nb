      RowBox[{"Pochhammer", "[", 
       RowBox[{"1", ",", 
        RowBox[{"n1", "+", "n3"}]}], "]"}], 
      RowBox[{"Pochhammer", "[", 
       RowBox[{"1", ",", 
        RowBox[{"n2", "+", "n3"}]}], "]"}], 
      RowBox[{"x", "^", "n1"}], " ", 
      RowBox[{"y", "^", "n2"}], " ", 
      RowBox[{"z", "^", "n3"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
