  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "TransportDE[PfaffianIN, ParSub, VarSub, {Eps, Ord}, NPrec, opts] \
numerically expands the function defined by the Pfaffian system PfaffianIN \
around Eps=0 up to order Ord with NPrec correct digits.\nPfaffianIN is the \
Pfaffian system returned by FindPfaffianSystem[] or \
FindPfaffianSystemBasis[].\nParSub is the list of substitution rules for the \
Pochhammer parameters:\n  \[Bullet] {a \[Rule] 1+\[Epsilon], b \[Rule] 1/2, c \
\[Rule] 2-\[Epsilon], ...}\nVarSub is the list of substitution rules for the \
kinematic variables, specifying the evaluation point:\n  \[Bullet] {x \[Rule] \
1/5, y \[Rule] 1/4, ...}\nThe result is the list of Laurent coefficients from \
the lowest non-vanishing order to Ord.\nOptions:\n  \[Bullet] IDelta      \
(default: -I)    \[LongDash] infinitesimal imaginary shift\n  \[Bullet] \
VerboseMode (default: False) \[LongDash] print progress information\n  \
\[Bullet] ParallelRun (default: True)  \[LongDash] use parallel evaluation\n\
Examples:\n  TransportDE[PfaffianSystemIN, {a \[Rule] 1, b1 \[Rule] 1/2, b2 \
\[Rule] 1/3, c \[Rule] 2}, {x \[Rule] 1/5, y \[Rule] 1/4}, {\[Epsilon], 2}, \
50]", "Documentation" -> None, "OwnValues" -> None, "UpValues" -> None, 
    "DownValues" -> 
    Information`InformationValueForm[
     DownValues, HyperPrecision`TransportDE, {HyperPrecision`TransportDE[
         Pattern[HyperPrecision`Private`PfaffianIN, 
          Blank[]], 
         Pattern[HyperPrecision`Private`ParSubRaw, 
          Blank[]], 
         Pattern[HyperPrecision`Private`VarsSubRaw, 
          Blank[]], {
          Pattern[HyperPrecision`Private`Eps, 
           Blank[]], 
          Pattern[HyperPrecision`Private`OrdRaw, 
           Blank[]]}, 
         Pattern[HyperPrecision`Private`NPrec, 
          Blank[]], 
         OptionsPattern[]] :> 
       Module[{HyperPrecision`Private`DiffEq, 
          HyperPrecision`Private`BoundaryVal, 
          HyperPrecision`Private`TransportLine, 
          HyperPrecision`Private`PoleList, 
          HyperPrecision`Private`RunSegmentOut, 
          HyperPrecision`Private`CurrentPoint, 
          HyperPrecision`Private`\[CapitalDelta], 
          HyperPrecision`Private`SingCurve, HyperPrecision`Private`Dim, 
          HyperPrecision`Private`DESolverQ, HyperPrecision`Private`DiffExpQ, 
          HyperPrecision`Private`DimBasis, HyperPrecision`Private`StartingQ, 
          HyperPrecision`Private`RecomputeBoundaryQ, 
          HyperPrecision`Private`BoundaryPoint, 
          HyperPrecision`Private`InitialBoundary, 
          HyperPrecision`Private`LimList, 
          HyperPrecision`Private`StartingPointVal, 
          HyperPrecision`Private`PrintVerbose, 
          HyperPrecision`Private`VerboseQ, HyperPrecision`Private`Vars, 
          HyperPrecision`Private`TargetPoint, 
          HyperPrecision`Private`ParallelQ, 
          HyperPrecision`Private`\[Epsilon]LOOut, HyperPrecision`Private`Ser, 
          HyperPrecision`Private`Pfaffian, HyperPrecision`Private`SumVar, 
          HyperPrecision`Private`Basis, HyperPrecision`Private`BasisPow, 
          HyperPrecision`Private`BasisSer, HyperPrecision`Private`\[Epsilon]Q,
           HyperPrecision`Private`Ord, HyperPrecision`Private`SingCurves, 
          HyperPrecision`Private`ParSub, HyperPrecision`Private`VarsSub}, 
         HyperPrecision`Private`ParSub = (
           Rationalize[#, 10^(-HyperPrecision`Private`NPrec)]& )[
           HyperPrecision`Private`ParSubRaw]; 
         HyperPrecision`Private`VarsSub = (
           Rationalize[#, 10^(-HyperPrecision`Private`NPrec)]& )[
           HyperPrecision`Private`VarsSubRaw]; 
         HyperPrecision`Private`VerboseQ = 
          OptionValue[HyperPrecision`VerboseMode]; 
         HyperPrecision`Private`ParallelQ = 
          OptionValue[HyperPrecision`ParallelRun]; 
         HyperPrecision`Private`\[CapitalDelta] = 
          OptionValue[HyperPrecision`IDelta]; 
         HyperPrecision`Private`Ser = 
          Part[HyperPrecision`Private`PfaffianIN, 1]; 
         HyperPrecision`Private`SumVar = 
          Part[HyperPrecision`Private`PfaffianIN, 2]; 
         HyperPrecision`Private`Pfaffian = 
          Part[HyperPrecision`Private`PfaffianIN, 3]; 
         HyperPrecision`Private`Basis = 
          Part[HyperPrecision`Private`PfaffianIN, 4]; 
         HyperPrecision`Private`Vars = Keys[HyperPrecision`Private`VarsSub]; 
         HyperPrecision`Private`TargetPoint = 
          Values[HyperPrecision`Private`VarsSub]; 
         HyperPrecision`Private`SingCurves = 
          HyperPrecision`Private`FindSingularCurves[
           HyperPrecision`Private`Pfaffian, HyperPrecision`Private`Vars]; If[
           MemberQ[
            ReplaceAll[
            HyperPrecision`Private`SingCurves, 
             HyperPrecision`Private`VarsSub], 0], 
           Print[
           "Warning! Target Point lies on a branch cut, so the result might \
be divergent in some cases."]]; 
         HyperPrecision`Private`BasisSer = 
          ReplaceAll[HyperPrecision`Private`Basis, {\[FormalF] -> Function[
               Evaluate[HyperPrecision`Private`Vars], 
               Evaluate[HyperPrecision`Private`Ser]]}]; 
         HyperPrecision`Private`PrintVerbose[
            Pattern[HyperPrecision`Private`args, 
             BlankNullSequence[]]] := If[HyperPrecision`Private`VerboseQ, 
            Print[HyperPrecision`Private`args]]; 
         HyperPrecision`Private`\[Epsilon]Q = (
           MemberQ[#, HyperPrecision`Private`Eps]& )[
            DeleteDuplicates[
             Cases[
              ExpandAll[
               ReplaceAll[
               HyperPrecision`Private`Ser, HyperPrecision`Private`ParSub]], 
              Condition[
               Pattern[HyperPrecision`Private`s, 
                Blank[Symbol]], Context[HyperPrecision`Private`s] =!= 
               "System`"], {0, Infinity}, Heads -> True]]]; 
         HyperPrecision`Private`Ord = HyperPrecision`Private`OrdRaw; 
         If[HyperPrecision`Private`\[Epsilon]Q, 
           HyperPrecision`Private`\[Epsilon]LOOut = 
           HyperPrecision`Private`\[Epsilon]LO[
            HyperPrecision`Private`Ser, HyperPrecision`Private`SumVar, 
             HyperPrecision`Private`ParSub, HyperPrecision`Private`Eps], 
           HyperPrecision`Private`Ord = 0; 
           HyperPrecision`Private`\[Epsilon]LOOut = 0]; 
         If[HyperPrecision`Private`\[Epsilon]LOOut > 
           HyperPrecision`Private`Ord, 
           Print["Cannot expand to order ", HyperPrecision`Private`Ord, 
             " in ", HyperPrecision`Private`Eps, 
             " because the function's lowest non-vanishing order is ", 
             HyperPrecision`Private`\[Epsilon]LOOut, "."]; Abort[], 
           HyperPrecision`Private`PrintVerbose[
           "Lowest Order of ", HyperPrecision`Private`Eps, ": ", 
            HyperPrecision`Private`\[Epsilon]LOOut]]; If[
           Not[
            MemberQ[{-I, I}, HyperPrecision`Private`\[CapitalDelta]]], 
           Print["IDelta can be only \[PlusMinus] I"]; Abort[]; Null]; 
         HyperPrecision`Private`Dim = Length[HyperPrecision`Private`Vars]; 
         HyperPrecision`Private`DESolverQ = False; 
         HyperPrecision`Private`DiffExpQ = False; 
         HyperPrecision`Private`DimBasis = Length[
            Part[HyperPrecision`Private`Pfaffian, 1, 1]]; 
         HyperPrecision`Private`StartingQ = False; 
         HyperPrecision`Private`RecomputeBoundaryQ = False; 
         HyperPrecision`Private`BoundaryPoint = 
          ConstantArray[0, HyperPrecision`Private`Dim]; 
         HyperPrecision`Private`BoundaryVal = 
          UnitVector[HyperPrecision`Private`DimBasis, 1]; 
         HyperPrecision`Private`PrintVerbose[
          "Starting Boundary Point \[Rule] ", 
           N[HyperPrecision`Private`BoundaryPoint]]; 
         HyperPrecision`Private`PrintVerbose[
          "Starting Boundary Value \[Rule] ", 
           N[HyperPrecision`Private`BoundaryVal]]; 
         HyperPrecision`Private`PrintVerbose[
          "Running DESolver for numerical evaluation"]; 
         HyperPrecision`Private`BoundaryVal = 
          HyperPrecision`Private`TransportDESolver[
           HyperPrecision`Private`BoundaryPoint, 
            HyperPrecision`Private`BoundaryVal, 
            HyperPrecision`Private`TargetPoint, 
            HyperPrecision`Private`Pfaffian, HyperPrecision`Private`Vars, 
            HyperPrecision`Private`ParSub, HyperPrecision`Private`NPrec, 
            HyperPrecision`Private`\[CapitalDelta], 
            HyperPrecision`Private`Dim, HyperPrecision`Private`VerboseQ, 
            HyperPrecision`Private`ParallelQ, {
            HyperPrecision`Private`Eps, HyperPrecision`Private`Ord}, 
            HyperPrecision`Private`\[Epsilon]LOOut, 
            HyperPrecision`Private`BasisSer, HyperPrecision`Private`SumVar, 
            HyperPrecision`Private`SingCurves]; $MaxPrecision = 
          Infinity; $MinPrecision = 0; If[HyperPrecision`Private`ParallelQ, 
           
           ParallelEvaluate[$MaxPrecision = Infinity; $MinPrecision = 0; 
            Null]]; HyperPrecision`Private`BoundaryVal]}], "SubValues" -> 
    None, "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> {
     HyperPrecision`IDelta -> Complex[0, -1], HyperPrecision`VerboseMode -> 
      False, HyperPrecision`ParallelRun -> True}, "Attributes" -> {}, 
    "FullName" -> "HyperPrecision`TransportDE"|>, False]]], "Output",
 CellChangeTimes->{3.986762289629444*^9, 3.9867623666685667`*^9, 
