Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"HypExpand[HypSeries, ParSub, VarSub, {Eps, Ord}, \
NPrec, opts] numerically expands a hypergeometric series HypSeries around \
Eps=0 up to order Ord with NPrec correct digits.\\nHypSeries is a \
hypergeometric series given in terms of Pochhammer functions.\\nParSub is the \
list of substitution rules for the Pochhammer parameters:\\n  \[Bullet] {a \
\[Rule] 1+\[Epsilon], b \[Rule] 1/2, c \[Rule] 2-\[Epsilon], ...}\\nVarSub is \
the list of substitution rules for the kinematic variables, specifying the \
evaluation point:\\n  \[Bullet] {x \[Rule] 1/5, y \[Rule] 1/4, ...}\\nThe \
result is the list of Laurent coefficients from the lowest non-vanishing \
order to Ord.\\nOptions:\\n  \[Bullet] IDelta      (default: -I)    \
\[LongDash] infinitesimal imaginary shift\\n  \[Bullet] VerboseMode (default: \
False) \[LongDash] print progress information\\n  \[Bullet] ParallelRun \
(default: True)  \[LongDash] use parallel evaluation\\nExamples:\\n  \
HypExpand[Pochhammer[a,m+n] Pochhammer[b1,m] Pochhammer[b2,n] / \
(Pochhammer[c,m+n] m! n!) x^m y^n,\\n            {a \[Rule] 1, b1 \[Rule] \
1/2, b2 \[Rule] 1/3, c \[Rule] 2}, {x \[Rule] 1/5, y \[Rule] 1/4}, \
{\[Epsilon], 2}, 50]\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"HypExpand", "[", 
                    
                    RowBox[{
                    "HyperPrecision`Private`HypSeries_", ",", 
                    "HyperPrecision`Private`ParSubRaw_", ",", 
                    "HyperPrecision`Private`VarsSubRaw_", ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`Eps_", ",", 
                    "HyperPrecision`Private`Ord_"}], "}"}], ",", 
                    "HyperPrecision`Private`NPrec_", ",", 
                    RowBox[{"HyperPrecision`Private`opts", ":", 
                    RowBox[{"OptionsPattern", "[", "]"}]}]}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`SumVar", ",", 
                    "HyperPrecision`Private`ActualVar", ",", 
                    "HyperPrecision`Private`VarSubKeys", ",", 
                    "HyperPrecision`Private`VarsSub", ",", 
                    "HyperPrecision`Private`infoser", ",", 
                    "HyperPrecision`Private`NewVarsSubRaw", ",", 
                    "HyperPrecision`Private`genser", ",", 
                    "HyperPrecision`Private`newinfoser"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`SumVar", "=", 
                    
                    RowBox[{"HyperPrecision`Private`indices", "[", 
                    "HyperPrecision`Private`HypSeries", "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`VarSubKeys", "=", 
                    
                    RowBox[{"Keys", "[", "HyperPrecision`Private`VarsSubRaw", 
                    "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`infoser", "=", 
                    RowBox[{"HyperPrecision`Private`info", "[", 
                    
                    RowBox[{"HyperPrecision`Private`SumVar", ",", 
                    "HyperPrecision`Private`HypSeries"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`newinfoser", "=", 
                    RowBox[{"ReplacePart", "[", 
                    RowBox[{"HyperPrecision`Private`infoser", ",", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"2", ",", 
                    RowBox[{"-", "1"}]}], "}"}], "\[Rule]", 
                    "HyperPrecision`Private`VarSubKeys"}]}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`NewVarsSubRaw", "=", 
                    RowBox[{"Thread", "[", 
                    RowBox[{"HyperPrecision`Private`VarSubKeys", "\[Rule]", 
                    RowBox[{"(", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`infoser", 
                    "\[LeftDoubleBracket]", 
                    RowBox[{"2", ",", 
                    RowBox[{"-", "1"}]}], "\[RightDoubleBracket]"}], "/.", 
                    "\[VeryThinSpace]", "HyperPrecision`Private`VarsSubRaw"}],
                     ")"}]}], "]"}]}], ";", 
                    RowBox[{"Return", "[", 
                    RowBox[{"HyperPrecision`Private`HypExpand0", "[", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`infotoseries", "[", 
                    
                    RowBox[{"HyperPrecision`Private`SumVar", ",", 
                    "HyperPrecision`Private`newinfoser"}], "]"}], ",", 
                    RowBox[{"Rationalize", "[", 
                    RowBox[{"HyperPrecision`Private`ParSubRaw", ",", 
                    SuperscriptBox["10", 
                    RowBox[{"-", "HyperPrecision`Private`NPrec"}]]}], "]"}], 
                    ",", "HyperPrecision`Private`SumVar", ",", 
                    RowBox[{"Rationalize", "[", 
                    RowBox[{"HyperPrecision`Private`NewVarsSubRaw", ",", 
