Cell[BoxData[
 RowBox[{
  RowBox[{"Hol3Cor1", "[", 
   RowBox[{"A_", ",", "B_"}], "]"}], ":=", 
  RowBox[{"N\[CapitalDelta]", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"dyz", "^", "2"}], ")"}], "^", 
    RowBox[{"(", 
     RowBox[{"\[Eta]", "-", "\[CapitalTheta]"}], ")"}]}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"\[Eta]", "/", "2"}], "-", "\[CapitalTheta]2"}], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"\[Eta]", "/", "2"}], "-", "\[CapitalTheta]3"}], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"\[CapitalTheta]", "-", "\[Eta]"}], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"\[CapitalTheta]2", "+", "\[CapitalTheta]3", "-", 
        RowBox[{"\[Eta]", "/", "2"}]}], "]"}], "*", 
      RowBox[{"S1", "[", 
       RowBox[{"A", ",", "B"}], "]"}]}], "+", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Eta]", "/", "2"}], "-", "\[CapitalTheta]2"}], ")"}]}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"\[CapitalTheta]2", "-", 
        RowBox[{"\[Eta]", "/", "2"}]}], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"\[Eta]", "/", "2"}], "-", "\[CapitalTheta]3"}], "]"}], " ", 
      RowBox[{"Gamma", "[", "\[CapitalTheta]3", "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"\[CapitalTheta]1", "+", "\[CapitalTheta]3", "-", 
        RowBox[{"\[Eta]", "/", "2"}]}], "]"}], "*", 
      RowBox[{"S2", "[", 
       RowBox[{"A", ",", "B"}], "]"}]}], "+", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[Eta]", "/", "2"}], "-", "\[CapitalTheta]3"}], ")"}]}], " ", 
