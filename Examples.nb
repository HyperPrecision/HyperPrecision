                    RowBox[{"DeleteDuplicates", "[", 
                    RowBox[{"Cases", "[", 
                    RowBox[{
                    RowBox[{"ExpandAll", "[", 
                    
                    RowBox[{"HyperPrecision`Private`Ser", "/.", 
                    "\[VeryThinSpace]", "HyperPrecision`Private`ParSub"}], 
                    "]"}], ",", 
                    RowBox[{"HyperPrecision`Private`s_Symbol", "/;", 
