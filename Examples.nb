Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"FindPfaffianSystemBasis[HypSeries, SumVar, Vars, \
Basis] is the same as FindPfaffianSystem[], except that the basis of \
derivatives is supplied by the user as the fourth argument Basis rather than \
constructed automatically.\\nHypSeries is a hypergeometric series given in \
terms of Pochhammer functions.\\nSumVar is the list of summation indices \
appearing in HypSeries:\\n  \[Bullet] {m, n, ...}\\nVars is the list of \
kinematic variables:\\n  \[Bullet] {x, y, ...}\\nBasis is the user-supplied \
list of basis elements (derivatives of the unknown function F):\\n  \[Bullet] \
{F[x,y], Derivative[0,1][F][x,y], Derivative[1,0][F][x,y], \
Derivative[1,1][F][x,y], ...}\\nThe result is the 4-tuple {HypSeries, SumVar, \
Pfaffian, Basis} in the input format expected by \
TransportDE[].\\nExamples:\\n  FindPfaffianSystemBasis[Pochhammer[a,m+n] \
Pochhammer[b,m] Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n,\\n      \
                    {m, n}, {x, y}, {F[x,y], Derivative[0,1][F][x,y], \
Derivative[1,0][F][x,y], Derivative[1,1][F][x,y]}]\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"FindPfaffianSystemBasis", "[", 
                    
                    RowBox[{
                    "HyperPrecision`Private`exp_", ",", 
                    "HyperPrecision`Private`indices_List", ",", 
                    "HyperPrecision`Private`vars_List", ",", 
                    "HyperPrecision`Private`basis_"}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`pde", ",", 
                    "HyperPrecision`Private`MaxOrder", ",", 
                    "HyperPrecision`Private`rules", ",", 
                    "HyperPrecision`Private`funcSymbol", ",", 
                    "HyperPrecision`Private`infoser", ",", 
                    "HyperPrecision`Private`genser", ",", 
                    "HyperPrecision`Private`result", ",", 
                    "HyperPrecision`Private`de"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`infoser", "=", 
                    RowBox[{"HyperPrecision`Private`info", "[", 
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`exp"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`genser", "=", 
                    RowBox[{"HyperPrecision`Private`generalser", "[", 
                    
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`infoser"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`funcSymbol", "=", 
                    RowBox[{"First", "[", 
                    RowBox[{"Cases", "[", 
                    RowBox[{"HyperPrecision`Private`basis", ",", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`f_Symbol", "[", "___", 
                    "]"}], "\[RuleDelayed]", "HyperPrecision`Private`f"}], 
                    ",", "\[Infinity]"}], "]"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`MaxOrder", "=", 
                    RowBox[{"Total", "[", 
                    RowBox[{"Cases", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`FindCornerDerivativesN", 
                    "[", 
                    RowBox[{
                    
                    RowBox[{"Variables", "[", "HyperPrecision`Private`basis", 
                    "]"}], ",", "HyperPrecision`Private`funcSymbol"}], "]"}], 
                    ",", 
                    RowBox[{
                    RowBox[{
                    SuperscriptBox["__", 
                    TagBox[
                    RowBox[{"(", "HyperPrecision`Private`seq__", ")"}], 
                    Derivative], MultilineFunction -> None], "[", "__", "]"}],
                     "\[RuleDelayed]", 
                    RowBox[{"Total", "[", 
                    RowBox[{"{", "HyperPrecision`Private`seq", "}"}], "]"}]}],
                     ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "\[Infinity]"}], "}"}]}], "]"}], 
                    "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`pde", "=", 
                    RowBox[{"PDEGenerator", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    ",", "HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`funcSymbol"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`rules", "=", 
                    RowBox[{"Flatten", "[", 
                    RowBox[{"Solve", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"#1", "\[Equal]", "0"}], "&"}], ")"}], "/@", 
                    "HyperPrecision`Private`pde"}], ",", 
                    
                    RowBox[{"HyperPrecision`Private`FindCornerDerivativesN", 
                    "[", 
                    RowBox[{
                    
                    RowBox[{"Variables", "[", "HyperPrecision`Private`pde", 
                    "]"}], ",", "HyperPrecision`Private`funcSymbol"}], 
                    "]"}]}], "]"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`result", "=", 
                    
                    RowBox[{"HyperPrecision`Private`FindPfaffianSystemFF0", 
                    "[", 
                    RowBox[{
                    RowBox[{"Join", "[", 
                    RowBox[{"HyperPrecision`Private`rules", ",", 
                    RowBox[{"Flatten", "[", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`FindDerivativesUniversal",
                     "[", 
                    RowBox[{"HyperPrecision`Private`rules", ",", "#1"}], 
                    "]"}], "&"}], ")"}], "/@", 
                    RowBox[{"Range", "[", 
                    RowBox[{"HyperPrecision`Private`MaxOrder", "+", "2"}], 
                    "]"}]}], "]"}]}], "]"}], ",", 
                    "HyperPrecision`Private`basis", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`funcSymbol"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`de", "=", 
                    RowBox[{"Cancel", "/@", 
                    RowBox[{"(", 
                    
                    RowBox[{"HyperPrecision`Private`result", "/.", 
                    "\[VeryThinSpace]", 
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
                    ")"}]}]}], ";", 
                    RowBox[{"Print", "[", 
                    
                    RowBox[{"\"The basis is \[Rule] \"", ",", 
