   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "FindPfaffianSystem[HypSeries, SumVar, Vars] derives the Pfaffian system \
associated with HypSeries, automatically constructing a basis of derivatives \
from the holonomic order of the system.\nHypSeries is a hypergeometric series \
given in terms of Pochhammer functions.\nSumVar is the list of summation \
indices appearing in HypSeries:\n  \[Bullet] {m, n, ...}\nVars is the list of \
kinematic variables:\n  \[Bullet] {x, y, ...}\nThe result is the 4-tuple \
{HypSeries, SumVar, Pfaffian, Basis}, where Pfaffian is the Association <|Var \
\[Rule] Matrix|> of connection matrices and Basis is the list of basis \
elements. The 4-tuple is the input format expected by TransportDE[].\n\
Examples:\n  FindPfaffianSystem[Pochhammer[a,m+n] Pochhammer[b,m] \
Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, {x, y}]", 
    "Documentation" -> None, "OwnValues" -> None, "UpValues" -> None, 
    "DownValues" -> 
    Information`InformationValueForm[
     DownValues, HyperPrecision`FindPfaffianSystem, {
      HyperPrecision`FindPfaffianSystem[
         Pattern[HyperPrecision`Private`exp, 
          Blank[]], 
         Pattern[HyperPrecision`Private`indices, 
          Blank[List]], 
         Pattern[HyperPrecision`Private`vars, 
          Blank[List]]] :> (
        HyperPrecision`FindPfaffianSystem[
         HyperPrecision`Private`exp, HyperPrecision`Private`indices, 
          HyperPrecision`Private`vars] = 
        Module[{HyperPrecision`Private`pde, HyperPrecision`Private`infoser, 
           HyperPrecision`Private`genser, Order, HyperPrecision`Private`basis,
            HyperPrecision`Private`funcSymbol, HyperPrecision`Private`allpde, 
           HyperPrecision`Private`higherDerivs, HyperPrecision`Private`xVars, 
           HyperPrecision`Private`ffVars, HyperPrecision`Private`ffEqs, 
           HyperPrecision`Private`rank, HyperPrecision`Private`rawbasis, 
           HyperPrecision`Private`seed, HyperPrecision`Private`lookfor, 
           HyperPrecision`Private`MaxDerivativeOrder, 
           HyperPrecision`Private`graphID, HyperPrecision`Private`inNode, 
           HyperPrecision`Private`solverNode, 
           HyperPrecision`Private`hStackNode, 
           HyperPrecision`Private`hmStackNode, 
           HyperPrecision`Private`learnData, HyperPrecision`Private`depVars, 
           HyperPrecision`Private`indepVars, HyperPrecision`Private`xToDeriv, 
           HyperPrecision`Private`depDerivs, 
           HyperPrecision`Private`indepDerivs, HyperPrecision`Private`DV, 
           HyperPrecision`Private`HV, HyperPrecision`Private`HStack, 
           HyperPrecision`Private`mvec, HyperPrecision`Private`rec, 
           HyperPrecision`Private`hmStackMat, HyperPrecision`Private`hmPerDir,
            HyperPrecision`Private`pfaffianMatrices, 
           HyperPrecision`Private`rawToIndep, HyperPrecision`Private`Nbasis, 
           HyperPrecision`Private`AvList}, 
          HyperPrecision`Private`funcSymbol = \[FormalF]; 
          HyperPrecision`Private`infoser = 
           HyperPrecision`Private`info[
            HyperPrecision`Private`indices, HyperPrecision`Private`exp]; 
          HyperPrecision`Private`genser = 
           HyperPrecision`Private`generalser[
            HyperPrecision`Private`indices, HyperPrecision`Private`infoser]; 
          Order = HyperPrecision`FindHypergeometricOrder[
             Part[HyperPrecision`Private`genser, 1], 
             HyperPrecision`Private`indices, HyperPrecision`Private`vars]; 
          HyperPrecision`Private`MaxDerivativeOrder = Total[Order - 1]; 
          HyperPrecision`Private`pde = ReplaceAll[
             HyperPrecision`PDEGenerator[
              Part[HyperPrecision`Private`genser, 1], 
              HyperPrecision`Private`indices, HyperPrecision`Private`vars, 
              HyperPrecision`Private`funcSymbol], 
             Part[HyperPrecision`Private`genser, 2]]; Which[Length[
              DeleteDuplicates[Order]] === 1, HyperPrecision`Private`seed = 
            HyperPrecision`Private`MaxDerivativeOrder + 1, True, 
            HyperPrecision`Private`seed = 
            HyperPrecision`Private`MaxDerivativeOrder + 2]; 
          HyperPrecision`Private`allpde = 
           HyperPrecision`Private`AllPDEs[
            HyperPrecision`Private`pde, HyperPrecision`Private`vars, Order, 
             HyperPrecision`Private`seed]; 
          HyperPrecision`Private`higherDerivs = Reverse[
             SortBy[
              DeleteDuplicates[
               Cases[HyperPrecision`Private`allpde, 
                Condition[
                 Pattern[HyperPrecision`Private`expr, 
                  Blank[]], 
                 Or[
                 Head[HyperPrecision`Private`expr] === 
                  HyperPrecision`Private`funcSymbol, 
                  MatchQ[
                   Head[HyperPrecision`Private`expr], 
                   Derivative[
                    BlankSequence[]][HyperPrecision`Private`funcSymbol]]]], {
                0, Infinity}]], {
              HyperPrecision`Private`TotalDerivOrder, 
               HyperPrecision`Private`MaxIndexOrder}]]; 
          HyperPrecision`Private`xVars = Array[\[FormalXi], 
             Length[HyperPrecision`Private`higherDerivs]]; 
          HyperPrecision`Private`ffEqs = ReplaceAll[
             Map[# == 0& , HyperPrecision`Private`allpde], 
             Thread[
             HyperPrecision`Private`higherDerivs -> 
              HyperPrecision`Private`xVars]]; 
          HyperPrecision`Private`ffVars = DeleteDuplicates[
             Cases[HyperPrecision`Private`ffEqs, 
              Blank[Symbol], Infinity]]; 
          HyperPrecision`Private`ffVars = 
           Complement[
            HyperPrecision`Private`ffVars, HyperPrecision`Private`xVars]; 
          HyperPrecision`Private`ffVars = DeleteDuplicates[
             Join[HyperPrecision`Private`ffVars, 
              Flatten[{HyperPrecision`Private`vars}]]]; 
          If[Length[HyperPrecision`Private`ffVars] == 0, 
            HyperPrecision`Private`ffVars = {\[FormalZ]}]; 
          HyperPrecision`Private`lookfor = ReplaceAll[
             Reverse[
              SortBy[
               HyperPrecision`Private`GenerateLatticeBasis[
               HyperPrecision`Private`funcSymbol, HyperPrecision`Private`vars,
                 HyperPrecision`Private`MaxDerivativeOrder], {
               HyperPrecision`Private`TotalDerivOrder, 
                HyperPrecision`Private`MaxIndexOrder}]], 
             Thread[
             HyperPrecision`Private`higherDerivs -> 
              HyperPrecision`Private`xVars]]; 
          HyperPrecision`Private`rank = ReplaceAll[
             ReplaceAll[
              HyperPrecision`Private`FFSolveNoReconstruct[
              HyperPrecision`Private`ffEqs, HyperPrecision`Private`ffVars, 
               HyperPrecision`Private`xVars, HyperPrecision`Private`lookfor], 
              Map[Reverse, 
               Thread[
               HyperPrecision`Private`higherDerivs -> 
                HyperPrecision`Private`xVars]]], 
             Part[HyperPrecision`Private`genser, 2]]; 
          HyperPrecision`Private`rawbasis = 
           SortBy[HyperPrecision`Private`rank, {
             HyperPrecision`Private`TotalDerivOrder, 
              HyperPrecision`Private`MaxIndexOrder}]; 
          HyperPrecision`Private`basis = Map[If[
              MatchQ[
               Head[#], 
               Derivative[
                BlankSequence[]][HyperPrecision`Private`funcSymbol]], # 
              Apply[Times, HyperPrecision`Private`vars^Apply[List, 
                  Part[#, 0, 0]]], #]& , HyperPrecision`Private`rawbasis]; 
          HyperPrecision`Private`lookfor = ReplaceAll[
             Reverse[
              SortBy[
               DeleteDuplicates[
                Cases[
                 Flatten[
                  Table[
                   D[
                   HyperPrecision`Private`rawbasis, 
                    HyperPrecision`Private`v], {
                   HyperPrecision`Private`v, HyperPrecision`Private`vars}]], 
                 Condition[
                  Pattern[HyperPrecision`Private`expr, 
                   Blank[]], 
                  Or[
                  Head[HyperPrecision`Private`expr] === 
                   HyperPrecision`Private`funcSymbol, 
                   MatchQ[
                    Head[HyperPrecision`Private`expr], 
                    Derivative[
                    BlankSequence[]][HyperPrecision`Private`funcSymbol]]]], {
                 0, Infinity}]], {
               HyperPrecision`Private`TotalDerivOrder, 
                HyperPrecision`Private`MaxIndexOrder}]], 
             Thread[
             HyperPrecision`Private`higherDerivs -> 
              HyperPrecision`Private`xVars]]; 
          HyperPrecision`Private`Nbasis = 
           Length[HyperPrecision`Private`basis]; 
          HyperPrecision`Private`graphID = "PfaffGraphFF"; 
          HyperPrecision`Private`inNode = "Input"; 
          HyperPrecision`Private`solverNode = "Solver"; 
          HyperPrecision`Private`hStackNode = "HStack"; 
          HyperPrecision`Private`hmStackNode = "HMStack"; 
          FiniteFlow`FFNewGraph[
           HyperPrecision`Private`graphID, HyperPrecision`Private`inNode, 
            HyperPrecision`Private`ffVars]; 
          FiniteFlow`FFAlgDenseSolver[
           HyperPrecision`Private`graphID, 
            HyperPrecision`Private`solverNode, {
            HyperPrecision`Private`inNode}, HyperPrecision`Private`ffVars, 
            HyperPrecision`Private`ffEqs, HyperPrecision`Private`xVars, 
            "NeededVars" -> HyperPrecision`Private`lookfor]; 
          FiniteFlow`FFSolverOnlyHomogeneous[
           HyperPrecision`Private`graphID, HyperPrecision`Private`solverNode]; 
          FiniteFlow`FFGraphOutput[
           HyperPrecision`Private`graphID, HyperPrecision`Private`solverNode]; 
          HyperPrecision`Private`learnData = 
           FiniteFlow`FFDenseSolverLearn[
            HyperPrecision`Private`graphID, HyperPrecision`Private`xVars]; 
          HyperPrecision`Private`depVars = 
           ReplaceAll["DepVars", HyperPrecision`Private`learnData]; 
          HyperPrecision`Private`indepVars = 
           ReplaceAll["IndepVars", HyperPrecision`Private`learnData]; 
          HyperPrecision`Private`xToDeriv = 
           Thread[HyperPrecision`Private`xVars -> 
             HyperPrecision`Private`higherDerivs]; 
          HyperPrecision`Private`depDerivs = 
           ReplaceAll[
            HyperPrecision`Private`depVars, HyperPrecision`Private`xToDeriv]; 
          HyperPrecision`Private`indepDerivs = 
           ReplaceAll[
            HyperPrecision`Private`indepVars, 
             HyperPrecision`Private`xToDeriv]; 
          HyperPrecision`Private`rawToIndep = Flatten[
             Map[
             FirstPosition[HyperPrecision`Private`indepDerivs, #, {0}, {1}]& ,
               HyperPrecision`Private`rawbasis]]; If[
            MemberQ[HyperPrecision`Private`rawToIndep, 0], 
            Message[
             MessageName[HyperPrecision`FindPfaffianSystem, "mismatch"]]]; 
          HyperPrecision`Private`DV = <||>; HyperPrecision`Private`HV = <||>; 
          Module[{HyperPrecision`Private`allDerivs = 
             Join[HyperPrecision`Private`indepDerivs, 
               HyperPrecision`Private`depDerivs]}, 
            Do[
             
             Module[{HyperPrecision`Private`dExprList, 
               HyperPrecision`Private`fullCoef, HyperPrecision`Private`nIndep = 
               Length[HyperPrecision`Private`indepDerivs]}, 
              HyperPrecision`Private`dExprList = Table[
                 D[
                  Part[
                  HyperPrecision`Private`basis, HyperPrecision`Private`i], 
                  HyperPrecision`Private`v], {
                 HyperPrecision`Private`i, HyperPrecision`Private`Nbasis}]; 
              HyperPrecision`Private`fullCoef = Normal[
                 Part[
                  CoefficientArrays[
                  HyperPrecision`Private`dExprList, 
                   HyperPrecision`Private`allDerivs], 2]]; 
              HyperPrecision`Private`DV[HyperPrecision`Private`v] = 
               Part[HyperPrecision`Private`fullCoef, All, 
                 Span[1, HyperPrecision`Private`nIndep]]; 
              HyperPrecision`Private`HV[HyperPrecision`Private`v] = 
               Part[HyperPrecision`Private`fullCoef, All, 
                 Span[HyperPrecision`Private`nIndep + 1, All]]; Null], {
             HyperPrecision`Private`v, HyperPrecision`Private`vars}]]; 
          HyperPrecision`Private`HStack = Flatten[
             Table[
              HyperPrecision`Private`HV[HyperPrecision`Private`v], {
              HyperPrecision`Private`v, HyperPrecision`Private`vars}], 1]; 
          FiniteFlow`FFAlgRatFunEval[
           HyperPrecision`Private`graphID, 
            HyperPrecision`Private`hStackNode, {
            HyperPrecision`Private`inNode}, HyperPrecision`Private`ffVars, 
            Flatten[HyperPrecision`Private`HStack]]; 
          FiniteFlow`FFAlgMatMul[
           HyperPrecision`Private`graphID, 
            HyperPrecision`Private`hmStackNode, {
            HyperPrecision`Private`hStackNode, 
             HyperPrecision`Private`solverNode}, 
            Length[HyperPrecision`Private`vars] HyperPrecision`Private`Nbasis, 
            Length[HyperPrecision`Private`depDerivs], 
            Length[HyperPrecision`Private`indepDerivs]]; 
          FiniteFlow`FFGraphOutput[
           HyperPrecision`Private`graphID, 
            HyperPrecision`Private`hmStackNode]; 
          HyperPrecision`Private`rec = 
           FiniteFlow`FFReconstructFunction[
            HyperPrecision`Private`graphID, HyperPrecision`Private`ffVars]; 
          FiniteFlow`FFDeleteGraph[HyperPrecision`Private`graphID]; 
          HyperPrecision`Private`hmStackMat = 
           Partition[HyperPrecision`Private`rec, 
             Length[HyperPrecision`Private`indepDerivs]]; 
          HyperPrecision`Private`hmPerDir = 
           Partition[
            HyperPrecision`Private`hmStackMat, HyperPrecision`Private`Nbasis]; 
          HyperPrecision`Private`hmPerDir = 
           ReplaceAll[HyperPrecision`Private`hmPerDir, 
             Part[HyperPrecision`Private`genser, 2]]; 
          HyperPrecision`Private`mvec = 
           HyperPrecision`Private`basis/HyperPrecision`Private`rawbasis; 
          HyperPrecision`Private`AvList = Table[
             
             Module[{HyperPrecision`Private`coefM, 
               HyperPrecision`Private`vCur = 
               Part[HyperPrecision`Private`vars, HyperPrecision`Private`idx]},
               HyperPrecision`Private`coefM = 
               HyperPrecision`Private`DV[HyperPrecision`Private`vCur] + 
                Part[HyperPrecision`Private`hmPerDir, 
                  HyperPrecision`Private`idx]; 
              HyperPrecision`Private`coefM = 
               Part[HyperPrecision`Private`coefM, All, 
                 HyperPrecision`Private`rawToIndep]; 
              Table[Part[
                 HyperPrecision`Private`coefM, HyperPrecision`Private`i, 
                  HyperPrecision`Private`j]/Part[
                HyperPrecision`Private`mvec, HyperPrecision`Private`j], {
                HyperPrecision`Private`i, HyperPrecision`Private`Nbasis}, {
                HyperPrecision`Private`j, HyperPrecision`Private`Nbasis}]], {
             HyperPrecision`Private`idx, 
              Length[HyperPrecision`Private`vars]}]; 
          HyperPrecision`Private`pfaffianMatrices = 
           AssociationThread[
            HyperPrecision`Private`vars -> HyperPrecision`Private`AvList]; {
           HyperPrecision`Private`exp, HyperPrecision`Private`indices, 
            HyperPrecision`Private`pfaffianMatrices, 
            HyperPrecision`Private`basis}])}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> None, "Attributes" -> {}, "FullName" -> 
    "HyperPrecision`FindPfaffianSystem"|>, False]]], "Output",
 CellChangeTimes->{3.986762411974927*^9, 3.9869390735930653`*^9, 
  3.9869391832166986`*^9, 3.987982480269837*^9, 3.9886512209991007`*^9, 
  3.988655740669057*^9, 3.988887622777603*^9, 3.9889030776218576`*^9, 
  3.988903480731604*^9},
 CellLabel->"Out[29]=",ExpressionUUID->"62fd132b-eb7e-4f66-9062-12277d49ff85"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"?", "FindPfaffianSystemBasis"}]], "Input",
 CellChangeTimes->{{3.9867624136445007`*^9, 3.986762422300001*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"2253d7e6-3d14-44e1-8c63-6773b4b93166"],

Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"FindPfaffianSystemBasis[HypSeries, SumVar, Vars, \
Basis] is the same as FindPfaffianSystem[], except that the basis of \
derivatives is supplied by the user as the fourth argument Basis rather than \
constructed automatically.\\nHypSeries is a hypergeometric series given in \
terms of Pochhammer functions.\\nSumVar is the list of summation indices \
appearing in HypSeries:\\n  \[Bullet] {m, n, ...}\\nVars is the list of \
kinematic variables:\\n  \[Bullet] {x, y, ...}\\nBasis is the user-supplied \
list of basis elements (derivatives of the unknown function F):\\n  \[Bullet] \
{F[x,y], Derivative[0,1][F][x,y], Derivative[1,0][F][x,y], \
Derivative[1,1][F][x,y], ...}\\nThe result is the 4-tuple {HypSeries, SumVar, \
Pfaffian, Basis} in the input format expected by \
TransportDE[].\\nExamples:\\n  FindPfaffianSystemBasis[Pochhammer[a,m+n] \
Pochhammer[b,m] Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n,\\n      \
                    {m, n}, {x, y}, {F[x,y], Derivative[0,1][F][x,y], \
Derivative[1,0][F][x,y], Derivative[1,1][F][x,y]}]\"\>", 
             "InformationUsageText",
