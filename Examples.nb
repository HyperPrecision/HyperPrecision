Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"TransportDE[PfaffianIN, ParSub, VarSub, {Eps, Ord}, \
NPrec, opts] numerically expands the function defined by the Pfaffian system \
PfaffianIN around Eps=0 up to order Ord with NPrec correct \
digits.\\nPfaffianIN is the Pfaffian system returned by FindPfaffianSystem[] \
or FindPfaffianSystemBasis[].\\nParSub is the list of substitution rules for \
the Pochhammer parameters:\\n  \[Bullet] {a \[Rule] 1+\[Epsilon], b \[Rule] \
1/2, c \[Rule] 2-\[Epsilon], ...}\\nVarSub is the list of substitution rules \
for the kinematic variables, specifying the evaluation point:\\n  \[Bullet] \
{x \[Rule] 1/5, y \[Rule] 1/4, ...}\\nThe result is the list of Laurent \
coefficients from the lowest non-vanishing order to Ord.\\nOptions:\\n  \
\[Bullet] IDelta      (default: -I)    \[LongDash] infinitesimal imaginary \
shift\\n  \[Bullet] VerboseMode (default: False) \[LongDash] print progress \
information\\n  \[Bullet] ParallelRun (default: True)  \[LongDash] use \
parallel evaluation\\nExamples:\\n  TransportDE[PfaffianSystemIN, {a \[Rule] \
1, b1 \[Rule] 1/2, b2 \[Rule] 1/3, c \[Rule] 2}, {x \[Rule] 1/5, y \[Rule] \
1/4}, {\[Epsilon], 2}, 50]\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"TransportDE", "[", 
                    
                    RowBox[{
                    "HyperPrecision`Private`PfaffianIN_", ",", 
                    "HyperPrecision`Private`ParSub_", ",", 
                    "HyperPrecision`Private`VarsSub_", ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`Eps_", ",", 
                    "HyperPrecision`Private`OrdRaw_"}], "}"}], ",", 
                    "HyperPrecision`Private`NPrec_", ",", 
                    RowBox[{"OptionsPattern", "[", "]"}]}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`DiffEq", ",", 
                    "HyperPrecision`Private`BoundaryVal", ",", 
                    "HyperPrecision`Private`TransportLine", ",", 
                    "HyperPrecision`Private`PoleList", ",", 
                    "HyperPrecision`Private`RunSegmentOut", ",", 
                    "HyperPrecision`Private`CurrentPoint", ",", 
                    "HyperPrecision`Private`\[CapitalDelta]", ",", 
                    "HyperPrecision`Private`SingCurve", ",", 
                    "HyperPrecision`Private`Dim", ",", 
                    "HyperPrecision`Private`DESolverQ", ",", 
                    "HyperPrecision`Private`DiffExpQ", ",", 
                    "HyperPrecision`Private`DimBasis", ",", 
                    "HyperPrecision`Private`StartingQ", ",", 
                    "HyperPrecision`Private`RecomputeBoundaryQ", ",", 
                    "HyperPrecision`Private`BoundaryPoint", ",", 
                    "HyperPrecision`Private`InitialBoundary", ",", 
                    "HyperPrecision`Private`LimList", ",", 
                    "HyperPrecision`Private`StartingPointVal", ",", 
                    "HyperPrecision`Private`PrintVerbose", ",", 
                    "HyperPrecision`Private`VerboseQ", ",", 
                    "HyperPrecision`Private`Vars", ",", 
                    "HyperPrecision`Private`TargetPoint", ",", 
                    "HyperPrecision`Private`ParallelQ", ",", 
                    "HyperPrecision`Private`\[Epsilon]LOOut", ",", 
                    "HyperPrecision`Private`Ser", ",", 
                    "HyperPrecision`Private`Pfaffian", ",", 
                    "HyperPrecision`Private`SumVar", ",", 
                    "HyperPrecision`Private`Basis", ",", 
                    "HyperPrecision`Private`BasisPow", ",", 
                    "HyperPrecision`Private`BasisSer", ",", 
                    "HyperPrecision`Private`\[Epsilon]Q", ",", 
                    "HyperPrecision`Private`Ord", ",", 
                    "HyperPrecision`Private`SingCurves"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`VerboseQ", "=", 
                    RowBox[{"OptionValue", "[", "VerboseMode", "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`ParallelQ", "=", 
                    RowBox[{"OptionValue", "[", "ParallelRun", "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`\[CapitalDelta]", "=", 
                    RowBox[{"OptionValue", "[", "IDelta", "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`Ser", "=", 
                    
                    RowBox[{"HyperPrecision`Private`PfaffianIN", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`SumVar", "=", 
                    
                    RowBox[{"HyperPrecision`Private`PfaffianIN", 
                    "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`Pfaffian", "=", 
                    
                    RowBox[{"HyperPrecision`Private`PfaffianIN", 
                    "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`Basis", "=", 
                    
                    RowBox[{"HyperPrecision`Private`PfaffianIN", 
                    "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`Vars", "=", 
                    
                    RowBox[{"Keys", "[", "HyperPrecision`Private`VarsSub", 
                    "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`TargetPoint", "=", 
                    
                    RowBox[{"Values", "[", "HyperPrecision`Private`VarsSub", 
                    "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`SingCurves", "=", 
                    RowBox[{"HyperPrecision`Private`FindSingularCurves", "[", 
                    
                    RowBox[{"HyperPrecision`Private`Pfaffian", ",", 
                    "HyperPrecision`Private`Vars"}], "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"MemberQ", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`SingCurves", "/.", 
                    "\[VeryThinSpace]", "HyperPrecision`Private`VarsSub"}], 
                    ",", "0"}], "]"}], ",", 
                    
                    RowBox[{"Print", "[", 
                    "\"Warning! Target Point lies on a branch cut, so the \
result might be incorrect.\"", "]"}]}], "]"}], ";", 
                    RowBox[{"HyperPrecision`Private`BasisSer", "=", 
                    
                    RowBox[{"HyperPrecision`Private`Basis", "/.", 
                    "\[VeryThinSpace]", 
                    RowBox[{"{", 
                    RowBox[{"\[FormalF]", "\[Rule]", 
                    RowBox[{"Function", "[", 
                    RowBox[{
                    
                    RowBox[{"Evaluate", "[", "HyperPrecision`Private`Vars", 
                    "]"}], ",", 
                    
                    RowBox[{"Evaluate", "[", "HyperPrecision`Private`Ser", 
                    "]"}]}], "]"}]}], "}"}]}]}], ";", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`PrintVerbose", "[", 
                    "HyperPrecision`Private`args___", "]"}], ":=", 
                    RowBox[{"If", "[", 
                    RowBox[{"HyperPrecision`Private`VerboseQ", ",", 
                    
                    RowBox[{"Print", "[", "HyperPrecision`Private`args", 
                    "]"}]}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`\[Epsilon]Q", "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"MemberQ", "[", 
                    RowBox[{"#1", ",", "HyperPrecision`Private`Eps"}], "]"}], 
                    "&"}], ")"}], "[", 
                    RowBox[{"Variables", "[", 
                    
                    RowBox[{"Values", "[", "HyperPrecision`Private`ParSub", 
                    "]"}], "]"}], "]"}]}], ";", 
                    
                    RowBox[{"HyperPrecision`Private`Ord", "=", 
                    "HyperPrecision`Private`OrdRaw"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{"HyperPrecision`Private`\[Epsilon]Q", ",", 
                    RowBox[{"HyperPrecision`Private`\[Epsilon]LOOut", "=", 
                    RowBox[{"HyperPrecision`Private`\[Epsilon]LO", "[", 
                    
                    RowBox[{"HyperPrecision`Private`Ser", ",", 
                    "HyperPrecision`Private`SumVar", ",", 
                    "HyperPrecision`Private`ParSub", ",", 
                    "HyperPrecision`Private`Eps"}], "]"}]}], ",", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`Ord", "=", "0"}], ";", 
                    
                    RowBox[{"HyperPrecision`Private`\[Epsilon]LOOut", "=", 
