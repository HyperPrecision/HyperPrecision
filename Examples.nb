  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "PDEGenerator[HypSeries, SumVar, Vars, FuncSymbol] returns the list of \
PDEs satisfied by HypSeries in the variables Vars, derived from the shift \
ratios of the series coefficients in the summation indices SumVar.\nHypSeries \
is a hypergeometric series given in terms of Pochhammer functions.\nSumVar is \
the list of summation indices appearing in HypSeries:\n  \[Bullet] {m, n, \
...}\nVars is the list of kinematic variables:\n  \[Bullet] {x, y, ...}\n\
FuncSymbol (optional, default F) sets the function symbol appearing in the \
output PDEs.\nThe result is a list of PDEs in the unknown function \
FuncSymbol[Vars].\nExamples:\n  PDEGenerator[Pochhammer[a,m+n] \
Pochhammer[b,m] Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, \
{x, y}]\n  PDEGenerator[Pochhammer[a,m+n] Pochhammer[b,m] Pochhammer[b',n] / \
(Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, {x, y}, G]", "Documentation" -> 
    None, "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, HyperPrecision`PDEGenerator, {HyperPrecision`PDEGenerator[
         Pattern[HyperPrecision`Private`series, 
          Blank[]], 
         Pattern[HyperPrecision`Private`indices, 
          Blank[List]], 
         Pattern[HyperPrecision`Private`var, 
          Blank[List]], 
         Optional[
          Pattern[HyperPrecision`Private`funcSymbol, 
           Blank[]], HyperPrecision`Private`F]] :> (
        HyperPrecision`PDEGenerator[
         HyperPrecision`Private`series, HyperPrecision`Private`indices, 
          HyperPrecision`Private`var, HyperPrecision`Private`funcSymbol] = 
        Module[{HyperPrecision`Private`coeff, HyperPrecision`Private`AA, 
           HyperPrecision`Private`applyTheta, HyperPrecision`Private`func}, 
          HyperPrecision`Private`coeff = FullSimplify[
             ReplaceAll[HyperPrecision`Private`series, 
              Thread[HyperPrecision`Private`var -> 1]]]; 
          HyperPrecision`Private`AA = Table[
             Through[
              {Numerator, Denominator}[
               FullSimplify[
               ReplaceAll[
                 HyperPrecision`Private`coeff, 
                  Part[HyperPrecision`Private`indices, 
                    HyperPrecision`Private`j] -> 
                  Part[HyperPrecision`Private`indices, 
                    HyperPrecision`Private`j] + 1]/
                HyperPrecision`Private`coeff]]], {HyperPrecision`Private`j, 1, 
              Length[HyperPrecision`Private`indices]}]; 
          HyperPrecision`Private`applyTheta[
             Pattern[HyperPrecision`Private`poly, 
              Blank[]], 
             Pattern[HyperPrecision`Private`expr, 
              Blank[]]] := 
           Module[{HyperPrecision`Private`rules}, 
             HyperPrecision`Private`rules = CoefficientRules[
                Expand[HyperPrecision`Private`poly], 
                HyperPrecision`Private`indices]; Total[
               Map[Part[#, 2] Fold[
                  
                  Function[{
                   HyperPrecision`Private`e, HyperPrecision`Private`vp}, 
                   Nest[Part[HyperPrecision`Private`vp, 1] D[#, 
                    Part[HyperPrecision`Private`vp, 1]]& , 
                    HyperPrecision`Private`e, 
                    Part[HyperPrecision`Private`vp, 2]]], 
                  HyperPrecision`Private`expr, 
                  Transpose[{HyperPrecision`Private`var, 
                    Part[#, 1]}]]& , HyperPrecision`Private`rules]]]; 
          HyperPrecision`Private`func = 
           Apply[HyperPrecision`Private`funcSymbol, 
             HyperPrecision`Private`var]; Table[
            Collect[
             Expand[HyperPrecision`Private`applyTheta[
                Part[HyperPrecision`Private`AA, HyperPrecision`Private`i, 2], 
                HyperPrecision`Private`func/Part[
                HyperPrecision`Private`var, HyperPrecision`Private`i]] - 
              HyperPrecision`Private`applyTheta[
               Part[HyperPrecision`Private`AA, HyperPrecision`Private`i, 1], 
               HyperPrecision`Private`func]], {
              BlankSequence[Derivative], 
              Apply[
              HyperPrecision`Private`funcSymbol, HyperPrecision`Private`var]},
              Simplify], {HyperPrecision`Private`i, 1, 
             Length[HyperPrecision`Private`indices]}]])}], "SubValues" -> 
    None, "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> None, "Attributes" -> {}, "FullName" -> 
    "HyperPrecision`PDEGenerator"|>, False]]], "Output",
