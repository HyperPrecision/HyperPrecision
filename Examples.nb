                    RowBox[{
                    RowBox[{"AppellF2", "[", 
                    
                    RowBox[{"HyperPrecision`Private`a_", ",", 
                    "HyperPrecision`Private`b1_", ",", 
                    "HyperPrecision`Private`b2_", ",", 
                    "HyperPrecision`Private`c1_", ",", 
                    "HyperPrecision`Private`c2_", ",", 
                    "HyperPrecision`Private`x_", ",", 
                    "HyperPrecision`Private`y_"}], "]"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`eps_", ",", 
                    "HyperPrecision`Private`Nterms_"}], "}"}], ",", 
                    "HyperPrecision`Private`Prec_", ",", 
                    RowBox[{"HyperPrecision`Private`opts", ":", 
