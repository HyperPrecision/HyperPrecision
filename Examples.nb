                    RowBox[{"SortBy", "[", 
                    RowBox[{"HyperPrecision`Private`sol", ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`TotalDerivOrder", ",", 
                    "HyperPrecision`Private`MaxIndexOrder"}], "}"}]}], 
                    "]"}]}], "}"}], "]"}]}]}], "]"}]}]}, {" "}}, 
