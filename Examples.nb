      RowBox[{"x", "^", "m"}], " ", 
      RowBox[{"y", "^", "n"}], " ", 
      RowBox[{"z", "^", "p"}]}], ")"}], "/", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"Pochhammer", "[", 
       RowBox[{"c1", ",", "m"}], "]"}], 
      RowBox[{"Pochhammer", "[", 
       RowBox[{"c2", ",", "n"}], "]"}], 
