 RowBox[{
  RowBox[{"p", "=", "2"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[Eta]", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
