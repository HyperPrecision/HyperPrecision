Cell[BoxData[
 RowBox[{"?", "IDelta"}]], "Input",
 CellChangeTimes->{
  3.875969908415757*^9, {3.875969961125163*^9, 3.875969963032817*^9}, {
   3.986762451555459*^9, 3.986762453575118*^9}},
