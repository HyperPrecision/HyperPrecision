   StripOnInput->False],
  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "FindHolonomicRank[HypSeries, SumVar, Vars] returns the holonomic rank of \
the Pfaffian system associated with the hypergeometric series HypSeries.\n\
HypSeries is a hypergeometric series given in terms of Pochhammer functions.\n\
SumVar is the list of summation indices appearing in HypSeries:\n  \[Bullet] \
{m, n, ...}\nVars is the list of kinematic variables:\n  \[Bullet] {x, y, \
...}\nThe result is the pair {N, Relations}, where N is the holonomic rank \
and Relations is a (possibly empty) list of linear relations among the \
candidate basis elements that reduce the lattice basis to a basis of size N.\n\
Examples:\n  FindHolonomicRank[Pochhammer[a,m+n] Pochhammer[b,m] \
Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, {x, y}]", 
    "Documentation" -> None, "OwnValues" -> None, "UpValues" -> None, 
    "DownValues" -> 
    Information`InformationValueForm[
     DownValues, HyperPrecision`FindHolonomicRank, {
      HyperPrecision`FindHolonomicRank[
         Pattern[HyperPrecision`Private`exp, 
          Blank[]], 
         Pattern[HyperPrecision`Private`indices, 
          Blank[List]], 
         Pattern[HyperPrecision`Private`vars, 
          Blank[List]]] :> 
       Module[{Order, HyperPrecision`Private`pde, 
          HyperPrecision`Private`rules, HyperPrecision`Private`funcSymbol, 
          HyperPrecision`Private`infoser, HyperPrecision`Private`genser, 
          HyperPrecision`Private`MaxDerivativeOrder}, 
         HyperPrecision`Private`funcSymbol = \[FormalF]; 
         HyperPrecision`Private`infoser = 
          HyperPrecision`Private`info[
           HyperPrecision`Private`indices, HyperPrecision`Private`exp]; 
         HyperPrecision`Private`genser = 
          HyperPrecision`Private`generalser[
           HyperPrecision`Private`indices, HyperPrecision`Private`infoser]; 
         Order = Max[
            HyperPrecision`Private`FindHypergeometricOrder[
            HyperPrecision`Private`indices, HyperPrecision`Private`vars, 
             Part[HyperPrecision`Private`genser, 1]]]; 
         HyperPrecision`Private`MaxDerivativeOrder = Order + 2; 
         HyperPrecision`Private`pde = HyperPrecision`PDEGenerator[
            Part[HyperPrecision`Private`genser, 1], 
            HyperPrecision`Private`indices, HyperPrecision`Private`vars, 
            HyperPrecision`Private`funcSymbol]; 
         HyperPrecision`Private`rules = Flatten[
            Solve[
             Map[# == 0& , HyperPrecision`Private`pde], 
             HyperPrecision`Private`FindCornerDerivativesN[
              Variables[HyperPrecision`Private`pde], 
              HyperPrecision`Private`funcSymbol]]]; ReplaceAll[
           HyperPrecision`Private`HolonomicRankFF[Order, 
            Join[HyperPrecision`Private`rules, 
             Flatten[
              Map[ReplaceAll[
                HyperPrecision`Private`FindDerivativesUniversal[
                HyperPrecision`Private`rules, #], 
                HyperPrecision`Private`rules]& , 
               Range[HyperPrecision`Private`MaxDerivativeOrder]]]], 
            HyperPrecision`Private`vars, HyperPrecision`Private`funcSymbol], 
           Part[HyperPrecision`Private`genser, 2]]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> None, "Attributes" -> {}, "FullName" -> 
    "HyperPrecision`FindHolonomicRank"|>, False]]], "Output",
 CellChangeTimes->{3.986762431388287*^9, 3.986939073672317*^9, 
  3.986939183284095*^9},
 CellLabel->"Out[29]=",ExpressionUUID->"a8f4d54c-e681-40d4-95f2-a99277c0688b"]
