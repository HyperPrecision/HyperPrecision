Cell[BoxData[
 InterpretationBox[
  StyleBox[
   FrameBox[
    DynamicModuleBox[{System`InformationDump`open$$ = False, 
     System`InformationDump`mouseOver$$ = False}, 
     PaneSelectorBox[{True->
      TagBox[GridBox[{
         {
          ItemBox[
           PaneBox[
            StyleBox[
             TagBox[
              TooltipBox[
               StyleBox["\<\" Symbol\"\>", "InformationRowLabel",
                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"FindHolonomicRank[HypSeries, SumVar, Vars] returns \
the holonomic rank of the Pfaffian system associated with the hypergeometric \
series HypSeries, together with an independent basis of derivatives realizing \
this rank.\\nHypSeries is a hypergeometric series given in terms of \
Pochhammer functions.\\nSumVar is the list of summation indices appearing in \
HypSeries:\\n  \[Bullet] {m, n, ...}\\nVars is the list of kinematic \
variables:\\n  \[Bullet] {x, y, ...}\\nThe result is the pair {N, Basis}, \
where N is the holonomic rank and Basis is a list of N independent \
derivatives of the unknown function F, sorted by total derivative order. The \
Basis can be passed directly to FindPfaffianSystemBasis[] as the \
user-supplied basis argument.\\nExamples:\\n  \
FindHolonomicRank[Pochhammer[a,m+n] Pochhammer[b,m] Pochhammer[b',n] / \
(Pochhammer[c,m+n] m! n!) x^m y^n, {m, n}, {x, y}]\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"FindHolonomicRank", "[", 
                    
                    RowBox[{
                    "HyperPrecision`Private`exp_", ",", 
                    "HyperPrecision`Private`indices_List", ",", 
                    "HyperPrecision`Private`vars_List"}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"Order", ",", "HyperPrecision`Private`pde", ",", 
                    "HyperPrecision`Private`rules", ",", 
                    "HyperPrecision`Private`funcSymbol", ",", 
                    "HyperPrecision`Private`infoser", ",", 
                    "HyperPrecision`Private`genser", ",", 
                    "HyperPrecision`Private`MaxDerivativeOrder", ",", 
                    "HyperPrecision`Private`allpde", ",", 
                    "HyperPrecision`Private`higherDerivs", ",", 
                    "HyperPrecision`Private`xVars", ",", 
                    "HyperPrecision`Private`ffVars", ",", 
                    "HyperPrecision`Private`ffEqs", ",", 
                    "HyperPrecision`Private`sol", ",", 
                    "HyperPrecision`Private`rank", ",", 
                    "HyperPrecision`Private`lookfor", ",", 
                    "HyperPrecision`Private`seed", ",", 
                    "HyperPrecision`Private`subs", ",", 
                    "HyperPrecision`Private`invsubs"}], "}"}], ",", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`funcSymbol", "=", 
                    "\[FormalF]"}], ";", 
                    RowBox[{"HyperPrecision`Private`infoser", "=", 
                    RowBox[{"HyperPrecision`Private`info", "[", 
                    
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`exp"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`genser", "=", 
                    RowBox[{"HyperPrecision`Private`generalser", "[", 
                    
                    RowBox[{"HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`infoser"}], "]"}]}], ";", 
                    RowBox[{"Order", "=", 
                    RowBox[{"FindHypergeometricOrder", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    ",", "HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`vars"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`MaxDerivativeOrder", "=", 
                    RowBox[{"Total", "[", 
                    RowBox[{"Order", "-", "1"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`pde", "=", 
                    RowBox[{
                    RowBox[{"PDEGenerator", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    ",", "HyperPrecision`Private`indices", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`funcSymbol"}], "]"}], "/.", 
                    "\[VeryThinSpace]", 
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}]}]}], ";", 
                    RowBox[{"Which", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{"DeleteDuplicates", "[", "Order", "]"}], "]"}], 
                    "===", "1"}], ",", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`seed", "=", 
                    
                    RowBox[{"HyperPrecision`Private`MaxDerivativeOrder", "+", 
                    "1"}]}], ";"}], ",", "True", ",", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`seed", "=", 
                    
                    RowBox[{"HyperPrecision`Private`MaxDerivativeOrder", "+", 
                    "2"}]}], ";"}]}], "]"}], ";", 
                    RowBox[{"HyperPrecision`Private`allpde", "=", 
                    RowBox[{"HyperPrecision`Private`AllPDEs", "[", 
                    
                    RowBox[{"HyperPrecision`Private`pde", ",", 
                    "HyperPrecision`Private`vars", ",", "Order", ",", 
                    "HyperPrecision`Private`seed"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`higherDerivs", "=", 
                    RowBox[{"Reverse", "[", 
                    RowBox[{"SortBy", "[", 
                    RowBox[{
                    RowBox[{"DeleteDuplicates", "[", 
                    RowBox[{"Cases", "[", 
                    RowBox[{"HyperPrecision`Private`allpde", ",", 
                    RowBox[{"HyperPrecision`Private`expr_", "/;", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"Head", "[", "HyperPrecision`Private`expr", "]"}],
                     "===", "HyperPrecision`Private`funcSymbol"}], "||", 
                    RowBox[{"MatchQ", "[", 
                    RowBox[{
                    RowBox[{"Head", "[", "HyperPrecision`Private`expr", "]"}],
                     ",", 
                    SuperscriptBox["HyperPrecision`Private`funcSymbol", 
                    TagBox[
                    RowBox[{"(", "__", ")"}], Derivative], MultilineFunction -> 
                    None]}], "]"}]}]}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "\[Infinity]"}], "}"}]}], "]"}], "]"}], 
                    ",", 
                    RowBox[{"{", 
                    RowBox[{"HyperPrecision`Private`TotalDerivOrder", ",", 
                    "HyperPrecision`Private`MaxIndexOrder"}], "}"}]}], "]"}], 
                    "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`xVars", "=", 
                    RowBox[{"Array", "[", 
                    RowBox[{"\[FormalXi]", ",", 
                    
                    RowBox[{"Length", "[", 
                    "HyperPrecision`Private`higherDerivs", "]"}]}], "]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`subs", "=", 
                    RowBox[{"Dispatch", "[", 
                    RowBox[{"Thread", "[", 
                    
                    RowBox[{"HyperPrecision`Private`higherDerivs", "\[Rule]", 
                    "HyperPrecision`Private`xVars"}], "]"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`invsubs", "=", 
                    RowBox[{"Dispatch", "[", 
                    RowBox[{"Thread", "[", 
                    
                    RowBox[{"HyperPrecision`Private`xVars", "\[Rule]", 
                    "HyperPrecision`Private`higherDerivs"}], "]"}], "]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`ffEqs", "=", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"#1", "\[Equal]", "0"}], "&"}], ")"}], "/@", 
                    "HyperPrecision`Private`allpde"}], "/.", 
                    "\[VeryThinSpace]", "HyperPrecision`Private`subs"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`ffVars", "=", 
                    RowBox[{"DeleteDuplicates", "[", 
                    RowBox[{"Cases", "[", 
                    
                    RowBox[{"HyperPrecision`Private`ffEqs", ",", "_Symbol", 
                    ",", "\[Infinity]"}], "]"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`ffVars", "=", 
                    RowBox[{"Complement", "[", 
                    
                    RowBox[{"HyperPrecision`Private`ffVars", ",", 
                    "HyperPrecision`Private`xVars"}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`ffVars", "=", 
                    RowBox[{"DeleteDuplicates", "[", 
                    RowBox[{"Join", "[", 
                    RowBox[{"HyperPrecision`Private`ffVars", ",", 
                    RowBox[{"Flatten", "[", 
                    RowBox[{"{", "HyperPrecision`Private`vars", "}"}], 
                    "]"}]}], "]"}], "]"}]}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"Length", "[", "HyperPrecision`Private`ffVars", 
                    "]"}], "\[Equal]", "0"}], ",", 
                    RowBox[{"HyperPrecision`Private`ffVars", "=", 
                    RowBox[{"{", "\[FormalZ]", "}"}]}]}], "]"}], ";", 
                    RowBox[{"HyperPrecision`Private`lookfor", "=", 
                    RowBox[{
                    RowBox[{"Reverse", "[", 
                    RowBox[{"SortBy", "[", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`GenerateLatticeBasis", 
                    "[", 
                    
                    RowBox[{"HyperPrecision`Private`funcSymbol", ",", 
                    "HyperPrecision`Private`vars", ",", 
                    "HyperPrecision`Private`MaxDerivativeOrder"}], "]"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`TotalDerivOrder", ",", 
                    "HyperPrecision`Private`MaxIndexOrder"}], "}"}]}], "]"}], 
                    "]"}], "/.", "\[VeryThinSpace]", 
                    "HyperPrecision`Private`subs"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`sol", "=", 
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`FFSolveNoReconstruct", 
                    "[", 
                    
                    RowBox[{"HyperPrecision`Private`ffEqs", ",", 
                    "HyperPrecision`Private`ffVars", ",", 
                    "HyperPrecision`Private`xVars", ",", 
                    "HyperPrecision`Private`lookfor"}], "]"}], "/.", 
                    "\[VeryThinSpace]", "HyperPrecision`Private`invsubs"}], 
                    "/.", "\[VeryThinSpace]", 
                    
                    RowBox[{"HyperPrecision`Private`genser", 
                    "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}]}]}], ";", 
                    RowBox[{"Return", "[", 
                    RowBox[{"{", 
                    RowBox[{
                    
                    RowBox[{"Length", "[", "HyperPrecision`Private`sol", 
                    "]"}], ",", 
                    RowBox[{"SortBy", "[", 
                    RowBox[{"HyperPrecision`Private`sol", ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`TotalDerivOrder", ",", 
                    "HyperPrecision`Private`MaxIndexOrder"}], "}"}]}], 
                    "]"}]}], "}"}], "]"}]}]}], "]"}]}]}, {" "}}, 
                  GridBoxAlignment -> {"Columns" -> {{Left}}}, 
