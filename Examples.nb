          Blank[List]]] :> 
       Module[{HyperPrecision`Private`pairs, HyperPrecision`Private`pfaffian, 
          HyperPrecision`Private`AllPair}, 
         If[Length[HyperPrecision`Private`vars] === 1, 
           HyperPrecision`Private`AllPair = {True}, 
           HyperPrecision`Private`pairs = 
