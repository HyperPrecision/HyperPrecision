Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"pre1", "[", 
    RowBox[{"x0_", ",", "y0_", ",", "z0_"}], "]"}], ":=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["x0", 
       RowBox[{"1", "-", "\[Epsilon]"}]], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"1", "-", "\[Epsilon]"}], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "\[Epsilon]"}], "]"}], " ", 
      RowBox[{"Gamma", "[", "\[Epsilon]", "]"}], " "}], 
     RowBox[{"Gamma", "[", 
      RowBox[{"2", "-", "\[Epsilon]"}], "]"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pre2", "[", 
    RowBox[{"x0_", ",", "y0_", ",", "z0_"}], "]"}], ":=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["y0", 
       RowBox[{"1", "-", "\[Epsilon]"}]], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"1", "-", "\[Epsilon]"}], "]"}], " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{
        RowBox[{"-", "1"}], "+", "\[Epsilon]"}], "]"}], " ", 
      RowBox[{"Gamma", "[", "\[Epsilon]", "]"}], " "}], 
     RowBox[{"Gamma", "[", 
      RowBox[{"2", "-", "\[Epsilon]"}], "]"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"pre3", "[", 
    RowBox[{"x0_", ",", "y0_", ",", "z0_"}], "]"}], ":=", " ", 
   RowBox[{
    RowBox[{"-", 
     SuperscriptBox["x0", 
      RowBox[{"1", "-", "\[Epsilon]"}]]}], " ", 
    SuperscriptBox["y0", 
     RowBox[{"1", "-", "\[Epsilon]"}]], " ", 
    SuperscriptBox[
     RowBox[{"Gamma", "[", 
