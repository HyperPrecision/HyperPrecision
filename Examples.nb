                StripOnInput->False],
               "\"Symbol\"",
               TooltipStyle->"TextStyling"],
              Annotation[#, "Symbol", "Tooltip"]& ], "InformationTitleText",
             StripOnInput->False,
             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"CheckIntegrability[PfaffianIN, Vars] checks the \
Frobenius integrability conditions d_j M_i - d_i M_j + [M_i, M_j] = 0 for \
every pair of variables in Vars.\\nPfaffianIN is the Pfaffian system \
(4-tuple) returned by FindPfaffianSystem[] or FindPfaffianSystemBasis[]; the \
connection matrices M_i are taken from it.\\nVars is the list of kinematic \
variables:\\n  \[Bullet] {x, y, ...}\\nThe check is performed numerically at \
a randomly chosen rational point. Prints PASSED or FAILED for each pair, and \
returns True if all pairs pass, False otherwise.\\nExamples:\\n  \
CheckIntegrability[PfaffianSystemIN, {x, y}]\"\>", "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"CheckIntegrability", "[", 
                    
                    RowBox[{
                    "HyperPrecision`Private`pfaffianRaw_", ",", 
                    "HyperPrecision`Private`vars_List"}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"HyperPrecision`Private`pairs", ",", 
                    "HyperPrecision`Private`pfaffian", ",", 
                    "HyperPrecision`Private`AllPair"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{
                    
                    RowBox[{"Length", "[", "HyperPrecision`Private`vars", 
                    "]"}], "===", "1"}], ",", 
                    RowBox[{"HyperPrecision`Private`AllPair", "=", 
                    RowBox[{"{", "True", "}"}]}], ",", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`pairs", "=", 
                    RowBox[{"Subsets", "[", 
                    RowBox[{"HyperPrecision`Private`vars", ",", 
                    RowBox[{"{", "2", "}"}]}], "]"}]}], ";", 
                    RowBox[{"HyperPrecision`Private`pfaffian", "=", 
                    
                    RowBox[{"HyperPrecision`Private`pfaffianRaw", 
                    "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]}], 
                    ";", 
                    RowBox[{"HyperPrecision`Private`AllPair", "=", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    
                    RowBox[{"HyperPrecision`Private`IntegrabilityCheckNum", 
                    "[", 
                    RowBox[{
                    RowBox[{"HyperPrecision`Private`pfaffian", "[", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], "]"}], ",", 
                    RowBox[{"HyperPrecision`Private`pfaffian", "[", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}], "]"}], ",", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "1", 
                    "\[RightDoubleBracket]"}], ",", 
                    
                    RowBox[{"#1", "\[LeftDoubleBracket]", "2", 
                    "\[RightDoubleBracket]"}]}], "]"}], "&"}], ")"}], "/@", 
                    "HyperPrecision`Private`pairs"}]}], ";"}]}], "]"}], ";", 
                    RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"And", "@@", "HyperPrecision`Private`AllPair"}], 
                    ",", 
                    RowBox[{"Print", "[", "\"PASSED!!\"", "]"}], ",", 
                    RowBox[{"Print", "[", "\"FAILED!!\"", "]"}]}], "]"}], ";", 
                    RowBox[{"Return", "[", 
                    RowBox[{"And", "@@", "HyperPrecision`Private`AllPair"}], 
                    "]"}]}]}], "]"}]}]}, {" "}}, 
                  GridBoxAlignment -> {"Columns" -> {{Left}}}, 
