  InformationData[<|
   "ObjectType" -> "Symbol", "Usage" -> 
    "FindPfaffianSystemBasis[HypSeries, SumVar, Vars, Basis] is the same as \
FindPfaffianSystem[], except that the basis of derivatives is supplied by the \
user as the fourth argument Basis rather than constructed automatically.\n\
HypSeries is a hypergeometric series given in terms of Pochhammer functions.\n\
SumVar is the list of summation indices appearing in HypSeries:\n  \[Bullet] \
{m, n, ...}\nVars is the list of kinematic variables:\n  \[Bullet] {x, y, \
...}\nBasis is the user-supplied list of basis elements (derivatives of the \
unknown function F):\n  \[Bullet] {F[x,y], Derivative[0,1][F][x,y], \
Derivative[1,0][F][x,y], Derivative[1,1][F][x,y], ...}\nThe result is the \
4-tuple {HypSeries, SumVar, Pfaffian, Basis} in the input format expected by \
TransportDE[].\nExamples:\n  FindPfaffianSystemBasis[Pochhammer[a,m+n] \
Pochhammer[b,m] Pochhammer[b',n] / (Pochhammer[c,m+n] m! n!) x^m y^n,\n       \
                   {m, n}, {x, y}, {F[x,y], Derivative[0,1][F][x,y], \
Derivative[1,0][F][x,y], Derivative[1,1][F][x,y]}]", "Documentation" -> None, 
    "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, HyperPrecision`FindPfaffianSystemBasis, {
      HyperPrecision`FindPfaffianSystemBasis[
         Pattern[HyperPrecision`Private`exp, 
          Blank[]], 
         Pattern[HyperPrecision`Private`indices, 
          Blank[List]], 
         Pattern[HyperPrecision`Private`vars, 
          Blank[List]], 
         Pattern[HyperPrecision`Private`basis, 
          Blank[]]] :> 
       Module[{HyperPrecision`Private`pde, HyperPrecision`Private`MaxOrder, 
          HyperPrecision`Private`rules, HyperPrecision`Private`funcSymbol, 
          HyperPrecision`Private`infoser, HyperPrecision`Private`genser, 
          HyperPrecision`Private`result, HyperPrecision`Private`de}, 
         HyperPrecision`Private`infoser = 
          HyperPrecision`Private`info[
           HyperPrecision`Private`indices, HyperPrecision`Private`exp]; 
         HyperPrecision`Private`genser = 
          HyperPrecision`Private`generalser[
           HyperPrecision`Private`indices, HyperPrecision`Private`infoser]; 
         HyperPrecision`Private`funcSymbol = First[
            Cases[
            HyperPrecision`Private`basis, Pattern[HyperPrecision`Private`f, 
               Blank[Symbol]][
               BlankNullSequence[]] :> HyperPrecision`Private`f, Infinity]]; 
         HyperPrecision`Private`MaxOrder = Total[
            Cases[
             HyperPrecision`Private`FindCornerDerivativesN[
              Variables[HyperPrecision`Private`basis], 
              HyperPrecision`Private`funcSymbol], Derivative[
               Pattern[HyperPrecision`Private`seq, 
                BlankSequence[]]][
               BlankSequence[]][
               BlankSequence[]] :> Total[{HyperPrecision`Private`seq}], {
             0, Infinity}]]; 
         HyperPrecision`Private`pde = HyperPrecision`PDEGenerator[
            Part[HyperPrecision`Private`genser, 1], 
            HyperPrecision`Private`indices, HyperPrecision`Private`vars, 
            HyperPrecision`Private`funcSymbol]; 
         HyperPrecision`Private`rules = Flatten[
            Solve[
             Map[# == 0& , HyperPrecision`Private`pde], 
             HyperPrecision`Private`FindCornerDerivativesN[
              Variables[HyperPrecision`Private`pde], 
              HyperPrecision`Private`funcSymbol]]]; 
         HyperPrecision`Private`result = 
          HyperPrecision`Private`FindPfaffianSystemFF0[
            Join[HyperPrecision`Private`rules, 
             Flatten[
              Map[
              HyperPrecision`Private`FindDerivativesUniversal[
               HyperPrecision`Private`rules, #]& , 
               Range[HyperPrecision`Private`MaxOrder + 2]]]], 
            HyperPrecision`Private`basis, HyperPrecision`Private`vars, 
            HyperPrecision`Private`funcSymbol]; 
         HyperPrecision`Private`de = Map[Cancel, 
            ReplaceAll[HyperPrecision`Private`result, 
             Part[HyperPrecision`Private`genser, 2]]]; 
         Print["The basis is \[Rule] ", HyperPrecision`Private`basis]; 
         Print["Pfaffian Matrix : ", 
           Thread[Keys[HyperPrecision`Private`de] -> Map[MatrixForm[#]& , 
              Values[HyperPrecision`Private`de]]]]; 
         Return[{HyperPrecision`Private`exp, HyperPrecision`Private`indices, 
            HyperPrecision`Private`de, HyperPrecision`Private`basis}]; 
         Null]}], "SubValues" -> None, "DefaultValues" -> None, "NValues" -> 
    None, "FormatValues" -> None, "Options" -> None, "Attributes" -> {}, 
    "FullName" -> "HyperPrecision`FindPfaffianSystemBasis"|>, 
   False]]], "Output",
